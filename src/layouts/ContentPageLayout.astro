---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import EngageContact from "../components/EngageContact.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import logoPng from "../assets/images/isov8-logo.png";
import {
  SITE_ORIGIN,
  breadcrumbJsonLd,
  type BreadcrumbEntry,
} from "../utils/site-meta";

interface TocItem {
  id: string;
  label: string;
}

interface Props {
  metaTitle: string;
  description: string;
  keywords?: string[];
  ogType?: string;
  /**
   * Either a single breadcrumb leaf name (auto-prepends Home) or a full list
   * of breadcrumb entries from Home onward.
   */
  breadcrumbName?: string;
  breadcrumbItems?: BreadcrumbEntry[];
  h1: string;
  h2?: string;
  h3?: string;
  sectionName?: string;
  publishedDate?: string;
  tocItems?: TocItem[];
  backHref?: string;
  jsonLdExtra?: object[];
}

const {
  metaTitle,
  description,
  keywords = [],
  ogType,
  breadcrumbName,
  breadcrumbItems,
  h1,
  h2,
  h3,
  sectionName,
  publishedDate,
  tocItems = [],
  backHref = "/",
  jsonLdExtra = [],
} = Astro.props;

const resolvedBreadcrumbs: BreadcrumbEntry[] =
  breadcrumbItems && breadcrumbItems.length > 0
    ? breadcrumbItems
    : [
        { name: "Home", item: `${SITE_ORIGIN}/` },
        ...(breadcrumbName ? [{ name: breadcrumbName }] : []),
      ];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [breadcrumbJsonLd(resolvedBreadcrumbs), ...jsonLdExtra],
};

const visibleBreadcrumbs: BreadcrumbEntry[] = resolvedBreadcrumbs.filter(
  (crumb) => crumb.name !== "Home",
);

const hasToc = tocItems.length > 0;
const hasSidebar = Astro.slots.has("sidebar");
---

<BaseLayout title={metaTitle} description={description} keywords={keywords} ogType={ogType}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <div class:list={["min-h-screen bg-white text-[#111111]", hasSidebar && "lg:pl-[350px]"]}>
    {hasSidebar && (
      <aside
        class="hidden border-b border-gray-300 bg-white lg:fixed lg:inset-y-0 lg:left-0 lg:z-20 lg:block lg:w-[350px] lg:overflow-y-auto lg:border-b-0 lg:border-r"
      >
        <slot name="sidebar" />
      </aside>
    )}

    <main id="main-content" tabindex="-1" class="min-h-screen bg-white">
      <EngageContact />
      <SiteHeader backHref={backHref} />
      <div class="bg-white px-8 py-10 lg:px-12 lg:py-12">
        <section class="relative my-6 overflow-hidden py-8 md:my-8 md:py-10 xl:my-0 xl:py-0">
          <Image
            src={logoPng}
            alt=""
            aria-hidden="true"
            class="block w-full"
            decoding="async"
          />

          <div class="absolute inset-0 pl-[48px] pr-8 text-left text-black">
            <div class="absolute left-[48px] top-1/2 max-w-5xl -translate-y-1/2 space-y-4 lg:space-y-5">
              {h3 && (
                <p class="max-w-4xl text-[1.3125rem] font-[400] leading-[1.5]">
                  {h3}
                </p>
              )}

              {sectionName && (
                <span class="block max-w-4xl text-[1.5rem] font-[700] leading-[1.5]">
                  ISOv8® by Containerking® - {sectionName}
                </span>
              )}

              <h1 class="text-[2.625rem] font-[600] leading-[1.08]">
                {h1}
              </h1>

              {h2 && (
                <p class="max-w-5xl text-[1.3125rem] font-[400] italic leading-[1.5]">
                  {h2}
                </p>
              )}

              {visibleBreadcrumbs.length > 0 && (
                <nav aria-label="Breadcrumb" class="max-w-5xl text-[1.125rem] font-[400] leading-[1.5]">
                  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
                    {visibleBreadcrumbs.map((crumb, idx) => {
                      const isLast = idx === visibleBreadcrumbs.length - 1;
                      const href = crumb.item
                        ? crumb.item.startsWith(SITE_ORIGIN)
                          ? crumb.item.slice(SITE_ORIGIN.length) || "/"
                          : crumb.item
                        : undefined;
                      return (
                        <li class="flex items-center gap-2">
                          {idx > 0 && <span aria-hidden="true">/</span>}
                          {isLast || !href ? (
                            <span aria-current={isLast ? "page" : undefined}>{crumb.name}</span>
                          ) : (
                            <a href={href} class="underline-offset-4 transition-colors hover:text-brand hover:underline">
                              {crumb.name}
                            </a>
                          )}
                        </li>
                      );
                    })}
                  </ol>
                </nav>
              )}
            </div>
          </div>
        </section>

        {hasToc ? (
          <div id="toc-region" class="mt-12 xl:relative xl:grid xl:grid-cols-[minmax(0,1fr)_280px] xl:gap-12">
            <div
              class="pointer-events-none absolute bottom-0 right-[304px] top-0 hidden w-px bg-gray-200 xl:block"
              aria-hidden="true"
            ></div>

            <div>
              <section class="pt-8 text-[#111111]">
                <slot />
              </section>
            </div>

            <aside id="toc-rail" class="mt-12 hidden xl:relative xl:mt-0 xl:block xl:self-stretch xl:justify-self-end xl:w-full xl:max-w-[280px] xl:pl-6">
              <div id="toc-panel" class="p-0">
                <h2 class="text-[1.25rem] font-[600] leading-tight text-black">
                  Table of Contents
                </h2>

                <nav aria-label="Table of contents" class="mt-5">
                  <ul class="space-y-3 text-left">
                    {tocItems.map((item) => (
                      <li>
                        <a
                          href={`#${item.id}`}
                          data-toc-link={item.id}
                          class="text-[1.0625rem] leading-[1.5] text-[#4b5563] transition-colors hover:text-brand hover:underline"
                          set:html={item.label}
                        />
                      </li>
                    ))}
                  </ul>
                </nav>
              </div>
            </aside>
          </div>
        ) : (
          <div class="mt-12 max-w-[1230px]">
            <slot />
          </div>
        )}

        {publishedDate && (
          <p class="mt-12 text-[0.9375rem] italic text-[#4b5563]">
            Published: {publishedDate}
          </p>
        )}

        <section class="mt-12 border-t border-gray-200 pt-8 text-[#111111]">
          <div class="space-y-4">
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              If you are considering commissioning a container office, workshop, storage unit or secure anti-vandal unit for site use and want clarity on structural suitability before specification is fixed, speak with ISOv8&reg;. A short early discussion prevents disproportionate reinforcement and reactive redesign.
            </p>
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; by ContainerKing&reg; Limited Scunthorpe, North Lincolnshire<br />Tel: <a href="tel:+441724870000" class="text-brand underline transition-opacity hover:opacity-80">01724 870000</a><br />Nationwide delivery across England, Scotland &amp; Wales
            </p>
          </div>
        </section>

        <section id="page-legal" aria-labelledby="page-legal-disclaimer-heading" class="mt-8 border-t border-gray-200 pt-8 text-[#111111]">
          <div class="space-y-3">
            <h2 id="page-legal-disclaimer-heading" class="text-[1.125rem] font-[600] leading-tight">Legal Disclaimer</h2>
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              The content provided in this document is for general information purposes only and is not intended to constitute legal, planning, building control, health and safety, or professional advice. Regulations and site-specific requirements vary widely across the UK. ISOv8&reg; by ContainerKing&reg; does not accept liability for actions taken, losses incurred, or decisions made based on the information provided. Always consult your local authority, planning department, building inspector, legal adviser, or relevant professional before starting any container project. Use of this document is entirely at your own risk. For more information, please see our <a href="/terms-of-use" class="text-brand underline transition-opacity hover:opacity-80">Terms of Use</a>.
            </p>
          </div>

          <div class="mt-8 space-y-3">
            <h2 class="text-[1.125rem] font-[600] leading-tight">Copyright Notice</h2>
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              &copy; 2026 ISOv8&reg; by ContainerKing&reg;. All rights reserved. You are welcome to link to this page or share brief excerpts for commentary, review, or non-commercial purposes, provided proper credit is given to ISOv8&reg; by ContainerKing&reg;. No part of this document may be reproduced, distributed, or transmitted in full in any form or by any means without prior written permission from ISOv8&reg; by ContainerKing&reg;.
            </p>
          </div>
        </section>
      </div>
      <SiteFooter />
    </main>
  </div>

  <script>
    const tocRail = document.getElementById("toc-rail");
    const tocPanel = document.getElementById("toc-panel");
    const tocRegion = document.getElementById("toc-region");
    const desktopMq = window.matchMedia("(min-width: 1280px)");

    const resetTocPanel = () => {
      if (!tocPanel) return;
      tocPanel.style.removeProperty("position");
      tocPanel.style.removeProperty("top");
      tocPanel.style.removeProperty("left");
      tocPanel.style.removeProperty("right");
      tocPanel.style.removeProperty("width");
    };

    const updateTocPanel = () => {
      if (!tocRail || !tocPanel || !tocRegion || !desktopMq.matches) {
        resetTocPanel();
        return;
      }

      resetTocPanel();

      const railRect = tocRail.getBoundingClientRect();
      const regionRect = tocRegion.getBoundingClientRect();
      const panelRect = tocPanel.getBoundingClientRect();
      const railTop = railRect.top + window.scrollY;
      const regionBottom = regionRect.bottom + window.scrollY;
      const panelNaturalLeft = panelRect.left;
      const panelNaturalWidth = panelRect.width;
      const panelOffsetWithinRail = panelNaturalLeft - railRect.left;
      const currentScroll = window.scrollY;
      const fixedTop = 24;
      const startPoint = railTop - fixedTop;
      const stopPoint = regionBottom - tocPanel.offsetHeight - fixedTop;

      if (currentScroll <= startPoint) {
        resetTocPanel();
        return;
      }

      if (currentScroll >= stopPoint) {
        tocPanel.style.position = "absolute";
        tocPanel.style.top = `${Math.max(regionBottom - railTop - tocPanel.offsetHeight, 0)}px`;
        tocPanel.style.left = `${panelOffsetWithinRail}px`;
        tocPanel.style.right = "auto";
        tocPanel.style.width = `${panelNaturalWidth}px`;
        return;
      }

      tocPanel.style.position = "fixed";
      tocPanel.style.top = `${fixedTop}px`;
      tocPanel.style.left = `${panelNaturalLeft}px`;
      tocPanel.style.right = "auto";
      tocPanel.style.width = `${panelNaturalWidth}px`;
    };

    updateTocPanel();
    window.addEventListener("scroll", updateTocPanel, { passive: true });
    window.addEventListener("resize", updateTocPanel);
    desktopMq.addEventListener("change", updateTocPanel);

    const tocLinks = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");
    if (tocLinks.length > 0) {
      const headingIds = Array.from(tocLinks)
        .map((link) => link.getAttribute("data-toc-link"))
        .filter((id): id is string => id !== null);
      const headingEls = headingIds
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);

      const setActive = (id: string) => {
        tocLinks.forEach((link) => {
          if (link.getAttribute("data-toc-link") === id) {
            link.classList.remove("text-[#4b5563]");
            link.classList.add("text-brand", "underline");
          } else {
            link.classList.add("text-[#4b5563]");
            link.classList.remove("text-brand", "underline");
          }
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
            }
          });
        },
        { rootMargin: "0px 0px -70% 0px", threshold: 0 }
      );

      headingEls.forEach((el) => observer.observe(el));
    }
  </script>
</BaseLayout>
