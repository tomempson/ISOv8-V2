---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Thank You | ISOv8"
  description="Thank you for getting in touch with ISOv8."
>
  <div class="flex min-h-screen flex-col bg-white text-[#111111]">
    <main id="main-content" class="flex flex-1 flex-col items-center justify-center px-6 py-16">
      <h1
        class="text-center text-[3.75rem] font-[700] uppercase leading-[1] tracking-tight text-[#1f1f1f] md:text-[5.625rem] lg:text-[7.5rem]"
      >
        Thank You
      </h1>

      <p class="mt-5 max-w-lg text-center text-[1.125rem] font-[400] leading-[1.8] text-[#6f6f6f]">
        We've received your enquiry and will be in touch shortly.
      </p>

      <a
        href="/"
        class="mt-10 inline-block rounded-md px-14 py-5 text-[1.25rem] font-[500] uppercase tracking-[0.05em] text-white transition-opacity duration-300 hover:opacity-85"
        style="background: linear-gradient(to right, #008eba, #00a9d3);"
      >
        Return Home
      </a>

      <div id="submission-summary" class="mt-12 hidden w-full max-w-4xl">
        <p class="mb-4 text-left text-[0.875rem] font-[500] uppercase text-[#6f6f6f]">
          Your Submission
        </p>
        <div class="rounded-[6px] border border-gray-300 bg-[#fafafa] px-6 py-5">
          <dl id="submission-fields" class="flex flex-col gap-2 text-[1rem]"></dl>
        </div>
      </div>
    </main>

    <SiteFooter />
  </div>

  <script is:inline>
    (() => {
      try {
        const raw = sessionStorage.getItem("engage-contact-data");
        if (!raw) return;

        const data = JSON.parse(raw);
        sessionStorage.removeItem("engage-contact-data");

        const labels = {
          name: "Name",
          telephone: "Telephone",
          "business-name": "Business Name",
          "enquiry-details": "Enquiry Details"
        };

        const container = document.getElementById("submission-fields");
        const wrapper = document.getElementById("submission-summary");
        if (!container || !wrapper) return;

        Object.entries(labels).forEach(([key, label]) => {
          const value = data[key];
          if (!value) return;

          const dt = document.createElement("dt");
          dt.className = "text-[1rem] font-[500] text-[#6f6f6f]";
          dt.textContent = label;

          const dd = document.createElement("dd");
          dd.className = "mt-0.5 mb-4 text-[1rem] leading-[1.6] text-[#1f1f1f]";
          dd.textContent = value;

          container.appendChild(dt);
          container.appendChild(dd);
        });

        wrapper.classList.remove("hidden");
      } catch (_) {}
    })();
  </script>
</BaseLayout>
