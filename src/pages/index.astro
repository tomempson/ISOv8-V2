---
import BaseLayout from "../layouts/BaseLayout.astro";
import EngageContact from "../components/EngageContact.astro";
import { structuralSidebarLinks } from "../data/structuralSidebarLinks";
import { phases } from "../data/phases";

const conversionImages = [
  {
    src: "airbnb-pod.webp",
    title: "Airbnb Pods",
    description: "Stand out and earn more. Our bespoke container Airbnb pods can be styled for wow-factor—compact, comfortable, and unforgettable. Ideal for short stays, guest retreats, or off-grid escapes. Eye-catching, insulated and made to impress - ready to explore high-impact pods with serious rental appeal."
  },
  {
    src: "art-studio.webp",
    title: "Arts, Crafts, Hobbyists Studios",
    description: "Space to focus, freedom to create. Our bespoke container studios can be designed for artists, makers and hobbyists who need room to think and time to make. Bright, secure and insulated for year-round comfort. Whether it's painting, sewing, or sculpting: ready to create your own custom craft space?"
  },
  {
    src: "play-room.webp",
    title: "BDSM Play Rooms",
    description: "Privacy. Control. Atmosphere. Our bespoke container conversions can be transformed into fully private BDSM playrooms: sound-insulated, secure, and built to your preferences. Create a space that feels safe, personal, and entirely yours - ready to explore discreet, made-to-measure playroom options?"
  },
