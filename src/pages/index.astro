---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import EngageContact from "../components/EngageContact.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { phases, phaseSidebarToSanity, sectionSidebarToSanity } from "../data/taxonomy";
import { getSidebarLinksGroupedByPhaseSection } from "../utils/sanity";

const groupedLinks = await getSidebarLinksGroupedByPhaseSection();

const sectionLinks: Record<string, { href: string; label: string }[]> = {};
for (const phase of phases) {
  const sanityPhase = phaseSidebarToSanity[phase.id];
  if (!sanityPhase) continue;
  for (const section of phase.sections) {
    const sanitySection = sectionSidebarToSanity[section.id];
    if (!sanitySection) continue;
    const links = groupedLinks[sanityPhase]?.[sanitySection] || [];
    if (links.length > 0) {
      sectionLinks[section.id] = links;
    }
  }
}

import logoMark from "../assets/images/isov8-logo-mark.svg";
import logoFull from "../assets/images/isov8-logo.svg";
import bulletPoint from "../assets/images/bullet-point.webp";

---

<BaseLayout title="ISOv8®" description="ISO Shipping Container Conversions for Businesses, Creatives & Commercial Sectors Across the UK">
  <main id="main-content" tabindex="-1">
    <EngageContact />

    <section class="relative h-screen overflow-hidden">
      <header class="absolute inset-x-0 top-0 z-30">
        <a
          href="/"
          aria-label="ISOv8 home"
          class="absolute right-8 top-[15px] lg:hidden"
        >
          <img
            src={logoMark.src}
            alt=""
            aria-hidden="true"
            class="w-16"
          />
        </a>

        <a
          href="/"
          aria-label="ISOv8 home"
          class="absolute left-1/2 top-[15px] hidden -translate-x-1/2 lg:block"
        >
          <img
            src={logoFull.src}
            alt=""
            aria-hidden="true"
            class="w-[300px] max-w-none"
          />
        </a>

        <div class="flex items-center justify-between gap-6 px-8 py-8 text-[1.25rem] font-medium text-white lg:px-12 lg:py-10">
          <button
            id="menu-toggle"
            type="button"
            aria-controls="menu-shell"
            aria-expanded="false"
            aria-label="Open menu"
            class="flex cursor-pointer items-center gap-4 text-white transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
          >
            <span class="flex w-10 flex-col gap-3" aria-hidden="true">
              <span class="h-0.5 w-full bg-current"></span>
              <span class="h-0.5 w-7 bg-current"></span>
              <span class="h-0.5 w-4 bg-current"></span>
            </span>
            <span class="hidden lg:inline">MENU</span>
          </button>

          <nav aria-label="Primary" class="hidden items-center gap-6 lg:flex lg:gap-10">
            <a href="/about-us">ABOUT US</a>
            <a href="/inside-v8">INSIDE V8</a>
          </nav>
        </div>
      </header>

      <div
        id="menu-overlay"
        class="pointer-events-none fixed inset-0 z-[35] bg-black/50 opacity-0 transition-opacity ease-out"
        aria-hidden="true"
        style="transition-duration: 1000ms;"
      ></div>

      <div
        id="menu-shell"
        role="dialog"
        aria-modal="true"
        aria-label="Site navigation"
        inert
        class="pointer-events-none fixed inset-y-0 left-0 z-40 flex h-dvh transition-transform ease-out will-change-transform"
        style="transform: translateX(-100%); transition-duration: 1000ms;"
      >
        <nav
          id="menu-panel"
          aria-label="Main menu"
          class="relative z-10 h-dvh w-[250px] overflow-y-auto overscroll-contain border-r border-gray-300 bg-white max-[950px]:w-dvw"
          aria-hidden="true"
        >
          <button
            id="menu-close"
            type="button"
            aria-controls="menu-shell"
            aria-label="Close menu"
            class="absolute left-8 top-8 flex cursor-pointer items-center gap-4 text-[1.25rem] font-medium text-black lg:left-12 lg:top-10 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand"
          >
            <span class="relative flex h-10 w-10 items-center justify-center" aria-hidden="true">
              <span class="absolute h-0.5 w-full rotate-45 bg-current"></span>
              <span class="absolute h-0.5 w-full -rotate-45 bg-current"></span>
            </span>
            <span>CLOSE</span>
          </button>

          <div class="flex flex-col gap-6 px-8 pt-28 lg:px-12 lg:pt-32">
            {phases.map((phase) => (
              <button
                id={`menu-${phase.id}-trigger`}
                type="button"
                aria-controls={`menu-${phase.id}-panel`}
                aria-expanded="false"
                class="phase-trigger inline-block cursor-pointer text-left text-[1.125rem] font-[400] leading-tight text-black transition-colors hover:text-brand hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
              >
                {phase.label}
              </button>
            ))}
          </div>
        </nav>

        {phases.map((phase) => (
          <div
            id={`menu-${phase.id}-panel`}
            role="navigation"
            aria-label={phase.label}
            class="phase-panel pointer-events-none relative z-0 hidden h-dvh w-[350px] shrink-0 overflow-y-auto overscroll-contain border-r border-gray-300 bg-white transition-transform ease-out will-change-transform max-[950px]:absolute max-[950px]:inset-y-0 max-[950px]:left-0 max-[950px]:z-20 max-[950px]:w-dvw"
            aria-hidden="true"
            style="transform: translateX(-100%); transition-duration: 1000ms;"
          >
            <Image
              src={phase.image}
              alt=""
              aria-hidden="true"
              class="mx-auto block h-[250px] w-[350px] object-cover max-[950px]:w-full"
              width={350}
              height={250}
              decoding="async"
            />

            <div class="mt-[50px] flex items-center gap-4 px-[45px]">
              <button
                id={`menu-${phase.id}-back`}
                type="button"
                aria-controls={`menu-${phase.id}-panel`}
                aria-label="Back to primary menu"
                class="phase-back flex h-5 w-5 shrink-0 cursor-pointer items-center justify-center text-black transition-colors hover:text-brand focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
              >
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M13 4L7 10L13 16"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>

              <p class="text-[1.25rem] font-[500] leading-tight text-black">
                {phase.label}
              </p>
            </div>

            <div class="mt-[60px] flex flex-col gap-6 px-[45px] pb-12">
              {phase.sections.map((section) => (
                sectionLinks[section.id] ? (
                  <button
                    id={`menu-${section.id}-trigger`}
                    type="button"
                    aria-controls={`menu-${section.id}-panel`}
                    aria-expanded="false"
                    data-section-trigger={section.id}
                    class="menu-articles-trigger inline-block cursor-pointer text-left text-[1.125rem] font-[400] leading-tight text-black transition-colors hover:text-brand hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                  >
                    {section.label}
                  </button>
                ) : (
                  <p class="inline-block text-left text-[1.125rem] font-[400] leading-tight text-[#999999]">
                    {section.label}
                  </p>
                )
              ))}
            </div>
          </div>
        ))}

        {phases.flatMap((phase) =>
          phase.sections
            .filter((section) => sectionLinks[section.id])
            .map((section) => (
              <div
                id={`menu-${section.id}-panel`}
                role="navigation"
                aria-label={section.label}
                data-section-panel={section.id}
                data-parent-phase={phase.id}
                class="section-panel pointer-events-none relative -z-10 hidden h-dvh w-[350px] shrink-0 overflow-y-auto overscroll-contain border-r border-gray-300 bg-white transition-transform ease-out will-change-transform max-[950px]:absolute max-[950px]:inset-y-0 max-[950px]:left-0 max-[950px]:z-30 max-[950px]:w-dvw"
                aria-hidden="true"
                style="transform: translateX(-100%); transition-duration: 1000ms;"
              >
                <div class="mt-[50px] flex items-center gap-4 px-[45px]">
                  <button
                    type="button"
                    aria-controls={`menu-${section.id}-panel`}
                    aria-label={`Back to ${phase.label} panel`}
                    data-section-back={section.id}
                    class="section-back flex h-5 w-5 shrink-0 cursor-pointer items-center justify-center text-black transition-colors hover:text-brand focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                  >
                    <svg
                      class="h-5 w-5"
                      viewBox="0 0 20 20"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M13 4L7 10L13 16"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </button>

                  <p class="text-[1.25rem] font-[500] leading-tight text-black">
                    {section.label}
                  </p>
                </div>

                <div class="mt-[60px] flex flex-col gap-6 px-[45px] pb-12">
                  {sectionLinks[section.id].map((link) => (
                    <a
                      href={link.href}
                      class="menu-tertiary-link inline-block cursor-pointer text-left text-[1.125rem] font-[400] leading-tight text-black transition-colors hover:text-brand hover:underline active:text-brand active:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            ))
        )}
      </div>

      <video
        class="absolute inset-0 h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      >
        <source src="/assets/images/banner.mp4" type="video/mp4" />
      </video>

      <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-black/65 via-black/20 to-transparent lg:h-36"></div>

      <h1
        class="absolute bottom-8 left-8 z-20 text-[2.1875rem] font-[600] leading-[1.1] text-white lg:bottom-12 lg:left-12"
      >
        <span class="flex items-start gap-3">
          <Image
            src={bulletPoint}
            alt=""
            aria-hidden="true"
            class="mt-1 h-7 w-auto shrink-0 object-contain"
          />
          <span>Shipping Container Conversions</span>
        </span>
        <span class="mt-1 flex items-start gap-3">
          <Image
            src={bulletPoint}
            alt=""
            aria-hidden="true"
            class="mt-1 h-7 w-auto shrink-0 object-contain"
          />
          <span>Anti-Vandal Buildings</span>
        </span>
      </h1>
    </section>
    <SiteFooter />
  </main>

  <style is:global>
    .phase-trigger:active,
    .phase-trigger.is-pressed,
    .phase-trigger[aria-expanded="true"] {
      color: var(--color-brand);
      text-decoration: underline;
    }

    .menu-articles-trigger:active,
    .menu-articles-trigger.is-pressed,
    .menu-articles-trigger[aria-expanded="true"] {
      color: var(--color-brand);
      text-decoration: underline;
    }

    .menu-secondary-link:active,
    .menu-secondary-link.is-pressed,
    .menu-tertiary-link:active,
    .menu-tertiary-link.is-pressed {
      color: var(--color-brand);
      text-decoration: underline;
    }
  </style>

  <script>
    const menuToggle = document.getElementById("menu-toggle");
    const menuOverlay = document.getElementById("menu-overlay");
    const menuShell = document.getElementById("menu-shell");
    const menuPanel = document.getElementById("menu-panel");
    const menuClose = document.getElementById("menu-close");

    const phaseTriggers = document.querySelectorAll(".phase-trigger");
    const phasePanels = document.querySelectorAll(".phase-panel");
    const phaseBackButtons = document.querySelectorAll(".phase-back");

    const sectionTriggers = document.querySelectorAll("[data-section-trigger]");
    const sectionPanels = document.querySelectorAll("[data-section-panel]");
    const sectionBackButtons = document.querySelectorAll("[data-section-back]");

    const sectionPanelById = new Map();
    sectionPanels.forEach((panel) => {
      sectionPanelById.set(panel.getAttribute("data-section-panel"), panel);
    });
    const sectionTriggerById = new Map();
    sectionTriggers.forEach((trigger) => {
      sectionTriggerById.set(trigger.getAttribute("data-section-trigger"), trigger);
    });

    let activeSectionPanel = null;
    let activeSectionTrigger = null;

    let lockedScrollY = 0;
    let pageLockCount = 0;

    const lockPageScroll = () => {
      if (pageLockCount === 0) {
        lockedScrollY = window.scrollY;
        document.documentElement.style.overflow = "hidden";
        document.body.style.position = "fixed";
        document.body.style.top = `-${lockedScrollY}px`;
        document.body.style.left = "0";
        document.body.style.right = "0";
        document.body.style.width = "100%";
        document.body.style.overflow = "hidden";
      }

      pageLockCount += 1;
    };

    const unlockPageScroll = () => {
      if (pageLockCount === 0) {
        return;
      }

      pageLockCount -= 1;

      if (pageLockCount > 0) {
        return;
      }

      document.documentElement.style.removeProperty("overflow");
      document.body.style.removeProperty("position");
      document.body.style.removeProperty("top");
      document.body.style.removeProperty("left");
      document.body.style.removeProperty("right");
      document.body.style.removeProperty("width");
      document.body.style.removeProperty("overflow");
      window.scrollTo(0, lockedScrollY);
    };

    if (menuToggle && menuOverlay && menuShell && menuPanel && menuClose) {
      let isMenuAnimating = false;
      let isPhaseAnimating = false;
      let isArticlesAnimating = false;
      let isSwitchingPhase = false;
      let isSwitchingSection = false;
      let activePhasePanel = null;
      let activePhaseTrigger = null;

      const isMenuOpen = () => menuToggle.getAttribute("aria-expanded") === "true";
      const isPhasePanelOpen = () => activePhasePanel !== null;
      const isArticlesPanelOpen = () => activeSectionPanel !== null;

      const syncMenuInteractivity = () => {
        const menuIsOpen = isMenuOpen();
        menuShell.style.pointerEvents = menuIsOpen ? "auto" : "none";
        if (menuIsOpen) {
          menuShell.removeAttribute("inert");
        } else {
          menuShell.setAttribute("inert", "");
        }
      };

      const setMenuShellTransform = (isOpen) => {
        menuShell.style.transform = isOpen ? "translateX(0)" : "translateX(-100%)";
      };

      const resetArticlesPanelState = () => {
        sectionTriggers.forEach((trigger) => {
          trigger.setAttribute("aria-expanded", "false");
        });
        sectionPanels.forEach((panel) => {
          panel.setAttribute("aria-hidden", "true");
          panel.classList.add("hidden");
          panel.classList.add("pointer-events-none");
          panel.classList.remove("pointer-events-auto");
          panel.style.transform = "translateX(-100%)";
          panel.style.removeProperty("z-index");
        });
        activeSectionPanel = null;
        activeSectionTrigger = null;
      };

      const resetAllPhasePanels = () => {
        phaseTriggers.forEach((trigger) => {
          trigger.setAttribute("aria-expanded", "false");
        });

        phasePanels.forEach((panel) => {
          panel.setAttribute("aria-hidden", "true");
          panel.classList.add("hidden");
          panel.classList.add("pointer-events-none");
          panel.classList.remove("pointer-events-auto");
          panel.style.transform = "translateX(-100%)";
        });

        resetArticlesPanelState();
        activePhasePanel = null;
        activePhaseTrigger = null;
      };

      const finishArticlesTransition = () => {
        if (!isArticlesAnimating) {
          return;
        }

        isArticlesAnimating = false;

        sectionPanels.forEach((panel) => {
          if (panel.getAttribute("aria-hidden") === "true") {
            panel.classList.add("hidden");
          }
        });

        syncMenuInteractivity();
      };

      const resetSinglePhasePanel = (trigger, panel) => {
        if (!trigger || !panel) {
          return;
        }

        trigger.setAttribute("aria-expanded", "false");
        panel.setAttribute("aria-hidden", "true");
        panel.classList.add("hidden");
        panel.classList.add("pointer-events-none");
        panel.classList.remove("pointer-events-auto");
        panel.style.transitionDuration = "0s";
        panel.style.transform = "translateX(-100%)";
        panel.offsetHeight;
        panel.style.transitionDuration = "1000ms";

        activePhasePanel = null;
        activePhaseTrigger = null;
      };

      const switchPhasePanel = (newTrigger, newPanel) => {
        if (!activePhasePanel || !activePhaseTrigger) {
          return;
        }

        if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase || isSwitchingSection) {
          return;
        }

        const oldPanel = activePhasePanel;
        const oldTrigger = activePhaseTrigger;
        const articlesWasOpen = isArticlesPanelOpen();
        const articlesPanelToClose = activeSectionPanel;
        const articlesTriggerToClose = activeSectionTrigger;

        isSwitchingPhase = true;
        isPhaseAnimating = true;

        const slideDistance = (oldPanel.offsetWidth + (articlesPanelToClose ? articlesPanelToClose.offsetWidth : 0)) + "px";

        if (articlesPanelToClose) {
          articlesTriggerToClose?.setAttribute("aria-expanded", "false");
          articlesPanelToClose.setAttribute("aria-hidden", "true");
          articlesPanelToClose.classList.add("pointer-events-none");
          articlesPanelToClose.classList.remove("pointer-events-auto");
          articlesPanelToClose.style.transform = "translateX(-" + slideDistance + ")";
          activeSectionPanel = null;
          activeSectionTrigger = null;
        }

        oldTrigger.setAttribute("aria-expanded", "false");
        oldPanel.setAttribute("aria-hidden", "true");
        oldPanel.classList.add("pointer-events-none");
        oldPanel.classList.remove("pointer-events-auto");
        oldPanel.style.transform = "translateX(-" + slideDistance + ")";

        activePhasePanel = null;
        activePhaseTrigger = null;

        if (menuToggle.getAttribute("aria-expanded") === "true") {
          setMenuShellTransform(true);
        }

        let handled = false;
        const proceed = () => {
          if (handled) {
            return;
          }
          handled = true;

          isPhaseAnimating = false;
          isSwitchingPhase = false;
          oldPanel.classList.add("hidden");

          if (articlesPanelToClose) {
            articlesPanelToClose.classList.add("hidden");
            articlesPanelToClose.style.removeProperty("z-index");
            articlesPanelToClose.style.transitionDuration = "0s";
            articlesPanelToClose.style.transform = "translateX(-100%)";
            articlesPanelToClose.offsetHeight;
            articlesPanelToClose.style.transitionDuration = "1000ms";
          }

          oldPanel.style.transitionDuration = "0s";
          oldPanel.style.transform = "translateX(-100%)";
          oldPanel.offsetHeight;
          oldPanel.style.transitionDuration = "1000ms";

          window.requestAnimationFrame(() => {
            setPhasePanelState(newTrigger, newPanel, true);
          });
        };

        oldPanel.addEventListener("transitionend", (e) => {
          if (e.propertyName === "transform") {
            proceed();
          }
        }, { once: true });

        setTimeout(proceed, 1100);
      };

      const finishPhaseTransition = () => {
        if (!isPhaseAnimating) {
          return;
        }

        isPhaseAnimating = false;

        phasePanels.forEach((panel) => {
          if (panel.getAttribute("aria-hidden") === "true") {
            panel.classList.add("hidden");
          }
        });

        sectionPanels.forEach((panel) => {
          if (panel.getAttribute("aria-hidden") === "true") {
            panel.classList.add("hidden");
          }
        });

        syncMenuInteractivity();
      };

      const setArticlesPanelState = (trigger, panel, isOpen) => {
        if (!trigger || !panel) {
          return;
        }

        const currentIsOpen = trigger.getAttribute("aria-expanded") === "true";
        if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase || isSwitchingSection || currentIsOpen === isOpen) {
          return;
        }

        isArticlesAnimating = true;
        trigger.setAttribute("aria-expanded", String(isOpen));
        panel.setAttribute("aria-hidden", String(!isOpen));
        syncMenuInteractivity();

        if (isOpen) {
          activeSectionPanel = panel;
          activeSectionTrigger = trigger;
          panel.style.transform = "translateX(-100%)";
          panel.classList.remove("hidden");

          window.requestAnimationFrame(() => {
            panel.classList.remove("pointer-events-none");
            panel.classList.add("pointer-events-auto");
            panel.style.transform = "translateX(0)";
            if (menuToggle.getAttribute("aria-expanded") === "true") {
              setMenuShellTransform(true);
            }
          });

          return;
        }

        panel.classList.add("pointer-events-none");
        panel.classList.remove("pointer-events-auto");
        panel.style.transform = "translateX(-100%)";
        activeSectionPanel = null;
        activeSectionTrigger = null;

        if (menuToggle.getAttribute("aria-expanded") === "true") {
          setMenuShellTransform(true);
        }
      };

      const setPhasePanelState = (trigger, panel, isOpen) => {
        if (!trigger || !panel) {
          return;
        }

        const currentIsOpen = trigger.getAttribute("aria-expanded") === "true";
        if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase || isSwitchingSection || currentIsOpen === isOpen) {
          return;
        }

        isPhaseAnimating = true;
        trigger.setAttribute("aria-expanded", String(isOpen));
        panel.setAttribute("aria-hidden", String(!isOpen));
        syncMenuInteractivity();

        if (isOpen) {
          activePhasePanel = panel;
          activePhaseTrigger = trigger;
          panel.style.transform = "translateX(-100%)";
          panel.classList.remove("hidden");

          window.requestAnimationFrame(() => {
            panel.classList.remove("pointer-events-none");
            panel.classList.add("pointer-events-auto");
            panel.style.transform = "translateX(0)";
            if (menuToggle.getAttribute("aria-expanded") === "true") {
              setMenuShellTransform(true);
            }
          });

          return;
        }

        panel.classList.add("pointer-events-none");
        panel.classList.remove("pointer-events-auto");
        panel.style.transform = "translateX(-100%)";
        activePhasePanel = null;
        activePhaseTrigger = null;

        if (menuToggle.getAttribute("aria-expanded") === "true") {
          setMenuShellTransform(true);
        }
      };

      const setMenuState = (isOpen) => {
        menuToggle.setAttribute("aria-expanded", String(isOpen));
        menuOverlay.setAttribute("aria-hidden", String(!isOpen));
        menuPanel.setAttribute("aria-hidden", String(!isOpen));
        menuOverlay.classList.toggle("opacity-0", !isOpen);
        menuOverlay.classList.toggle("opacity-100", isOpen);
        setMenuShellTransform(isOpen);

        if (!isOpen) {
          phaseTriggers.forEach((trigger) => {
            trigger.setAttribute("aria-expanded", "false");
          });
          phasePanels.forEach((panel) => {
            panel.classList.add("pointer-events-none");
            panel.classList.remove("pointer-events-auto");
          });
        }

        syncMenuInteractivity();
      };

      const finishMenuTransition = () => {
        if (!isMenuAnimating) {
          return;
        }

        isMenuAnimating = false;
        const isOpen = isMenuOpen();
        menuOverlay.classList.toggle("pointer-events-none", !isOpen);
        menuOverlay.classList.toggle("pointer-events-auto", isOpen);
        if (!isOpen) {
          resetAllPhasePanels();
          unlockPageScroll();
        }
        syncMenuInteractivity();
      };

      const requestMenuState = (nextIsOpen) => {
        const currentIsOpen = isMenuOpen();
        if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase || isSwitchingSection || currentIsOpen === nextIsOpen) {
          return;
        }

        isMenuAnimating = true;
        menuOverlay.classList.remove("pointer-events-none");
        menuOverlay.classList.add("pointer-events-auto");
        if (nextIsOpen) {
          lockPageScroll();
        }
        setMenuState(nextIsOpen);
      };

      const trapFocus = (event) => {
        let focusPanel;
        if (isArticlesPanelOpen()) {
          focusPanel = activeSectionPanel;
        } else if (isPhasePanelOpen()) {
          focusPanel = activePhasePanel;
        } else {
          focusPanel = menuPanel;
        }

        const focusableElements = focusPanel.querySelectorAll(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );

        if (focusableElements.length === 0) {
          return;
        }

        const firstFocusable = focusableElements[0];
        const lastFocusable = focusableElements[focusableElements.length - 1];

        if (event.shiftKey && document.activeElement === firstFocusable) {
          event.preventDefault();
          lastFocusable.focus();
        } else if (!event.shiftKey && document.activeElement === lastFocusable) {
          event.preventDefault();
          firstFocusable.focus();
        }
      };

      menuToggle.addEventListener("click", (event) => {
        requestMenuState(true);
        if (event.detail === 0) {
          menuClose.focus();
        }
      });

      menuClose.addEventListener("click", (event) => {
        requestMenuState(false);
        if (event.detail === 0) {
          menuToggle.focus();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (!isMenuOpen()) {
          return;
        }

        if (event.key === "Escape") {
          event.preventDefault();
          if (isArticlesPanelOpen()) {
            setArticlesPanelState(activeSectionTrigger, activeSectionPanel, false);
          } else if (isPhasePanelOpen()) {
            setPhasePanelState(activePhaseTrigger, activePhasePanel, false);
          } else {
            requestMenuState(false);
            menuToggle.focus();
          }
        }

        if (event.key === "Tab") {
          trapFocus(event);
        }
      });

      phaseTriggers.forEach((trigger) => {
        const panelId = trigger.getAttribute("aria-controls");
        const panel = document.getElementById(panelId);

        if (panel) {
          trigger.addEventListener("click", () => {
            const isOpen = trigger.getAttribute("aria-expanded") === "true";

            if (!isOpen && activePhasePanel && activePhasePanel !== panel) {
              switchPhasePanel(trigger, panel);
              return;
            }

            setPhasePanelState(trigger, panel, !isOpen);
          });
        }
      });

      phaseBackButtons.forEach((backBtn) => {
        backBtn.addEventListener("click", () => {
          if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase || isSwitchingSection) {
            return;
          }

          const panel = backBtn.closest(".phase-panel");
          const trigger = document.getElementById(panel.id.replace("-panel", "-trigger"));

          isPhaseAnimating = true;

          const articlesPanelToClose = activeSectionPanel;
          const articlesTriggerToClose = activeSectionTrigger;
          const slideDistance = (panel.offsetWidth + (articlesPanelToClose ? articlesPanelToClose.offsetWidth : 0)) + "px";

          if (articlesPanelToClose) {
            articlesTriggerToClose?.setAttribute("aria-expanded", "false");
            articlesPanelToClose.setAttribute("aria-hidden", "true");
            articlesPanelToClose.classList.add("pointer-events-none");
            articlesPanelToClose.classList.remove("pointer-events-auto");
            articlesPanelToClose.style.transform = "translateX(-" + slideDistance + ")";
            activeSectionPanel = null;
            activeSectionTrigger = null;
          }

          trigger?.setAttribute("aria-expanded", "false");
          panel.setAttribute("aria-hidden", "true");
          panel.classList.add("pointer-events-none");
          panel.classList.remove("pointer-events-auto");
          panel.style.transform = "translateX(-" + slideDistance + ")";

          activePhasePanel = null;
          activePhaseTrigger = null;

          if (menuToggle.getAttribute("aria-expanded") === "true") {
            setMenuShellTransform(true);
          }
        });
      });

      const switchSectionPanel = (newTrigger, newPanel) => {
        if (!activeSectionPanel || !activeSectionTrigger) {
          return;
        }

        if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase || isSwitchingSection) {
          return;
        }

        const oldPanel = activeSectionPanel;
        const oldTrigger = activeSectionTrigger;

        isSwitchingSection = true;
        isArticlesAnimating = true;

        const slideDistance = oldPanel.offsetWidth + "px";

        oldTrigger.setAttribute("aria-expanded", "false");
        oldPanel.setAttribute("aria-hidden", "true");
        oldPanel.classList.add("pointer-events-none");
        oldPanel.classList.remove("pointer-events-auto");
        oldPanel.style.transform = "translateX(-" + slideDistance + ")";

        activeSectionPanel = null;
        activeSectionTrigger = null;

        if (menuToggle.getAttribute("aria-expanded") === "true") {
          setMenuShellTransform(true);
        }

        let handled = false;
        const proceed = () => {
          if (handled) return;
          handled = true;

          isArticlesAnimating = false;
          isSwitchingSection = false;
          oldPanel.classList.add("hidden");

          oldPanel.style.transitionDuration = "0s";
          oldPanel.style.transform = "translateX(-100%)";
          oldPanel.offsetHeight;
          oldPanel.style.transitionDuration = "1000ms";

          window.requestAnimationFrame(() => {
            setArticlesPanelState(newTrigger, newPanel, true);
          });
        };

        oldPanel.addEventListener("transitionend", (e) => {
          if (e.propertyName === "transform") {
            proceed();
          }
        }, { once: true });

        setTimeout(proceed, 1100);
      };

      sectionTriggers.forEach((trigger) => {
        const sectionId = trigger.getAttribute("data-section-trigger");
        const panel = sectionPanelById.get(sectionId);
        if (!panel) return;

        trigger.addEventListener("click", () => {
          const isOpen = trigger.getAttribute("aria-expanded") === "true";

          if (!isOpen && activeSectionPanel && activeSectionPanel !== panel) {
            switchSectionPanel(trigger, panel);
            return;
          }

          setArticlesPanelState(trigger, panel, !isOpen);
        });
      });

      sectionBackButtons.forEach((backBtn) => {
        backBtn.addEventListener("click", () => {
          const sectionId = backBtn.getAttribute("data-section-back");
          const panel = sectionPanelById.get(sectionId);
          const trigger = sectionTriggerById.get(sectionId);
          if (panel && trigger) {
            setArticlesPanelState(trigger, panel, false);
          }
        });
      });

      menuShell.addEventListener("touchstart", (event) => {
        const target = event.target.closest(
          ".phase-trigger, .menu-articles-trigger, .menu-secondary-link, .menu-tertiary-link"
        );
        if (target) target.classList.add("is-pressed");
      }, { passive: true });

      menuShell.addEventListener("touchend", (event) => {
        const pressed = menuShell.querySelector(".is-pressed");
        if (pressed) pressed.classList.remove("is-pressed");
      });

      menuShell.addEventListener("touchcancel", () => {
        const pressed = menuShell.querySelector(".is-pressed");
        if (pressed) pressed.classList.remove("is-pressed");
      });

      menuShell.addEventListener("transitionend", (event) => {
        if (event.propertyName === "transform" && isMenuAnimating) {
          finishMenuTransition();
        }
      });

      phasePanels.forEach((panel) => {
        panel.addEventListener("transitionend", (event) => {
          if (event.propertyName === "transform" && isPhaseAnimating) {
            finishPhaseTransition();
          }
        });
      });

      sectionPanels.forEach((panel) => {
        panel.addEventListener("transitionend", (event) => {
          if (event.propertyName === "transform" && isArticlesAnimating) {
            finishArticlesTransition();
          }
        });
      });

      // Restore sidebar state from query params (e.g. /?phase=phase-1&section=base-platforms)
      const urlParams = new URLSearchParams(window.location.search);
      const openPhase = urlParams.get("phase");
      const openSection = urlParams.get("section");

      if (openPhase) {
        const trigger = document.getElementById(`menu-${openPhase}-trigger`);
        const panel = document.getElementById(`menu-${openPhase}-panel`);

        if (trigger && panel) {
          // Instantly set menu open (no animation)
          lockPageScroll();
          menuToggle.setAttribute("aria-expanded", "true");
          menuOverlay.setAttribute("aria-hidden", "false");
          menuOverlay.classList.remove("opacity-0", "pointer-events-none");
          menuOverlay.classList.add("opacity-100", "pointer-events-auto");
          menuPanel.setAttribute("aria-hidden", "false");
          menuShell.style.transitionDuration = "0s";
          setMenuShellTransform(true);
          syncMenuInteractivity();

          // Instantly set phase panel open (no animation)
          trigger.setAttribute("aria-expanded", "true");
          panel.setAttribute("aria-hidden", "false");
          panel.classList.remove("hidden", "pointer-events-none");
          panel.classList.add("pointer-events-auto");
          panel.style.transitionDuration = "0s";
          panel.style.transform = "translateX(0)";
          activePhasePanel = panel;
          activePhaseTrigger = trigger;

          // If the section matches a section trigger, open it too
          let restoredSectionPanel = null;
          if (openSection) {
            const sectionTrigger = sectionTriggerById.get(openSection);
            const sectionPanel = sectionPanelById.get(openSection);
            if (sectionTrigger && sectionPanel) {
              sectionTrigger.setAttribute("aria-expanded", "true");
              sectionPanel.setAttribute("aria-hidden", "false");
              sectionPanel.classList.remove("hidden", "pointer-events-none");
              sectionPanel.classList.add("pointer-events-auto");
              sectionPanel.style.transitionDuration = "0s";
              sectionPanel.style.transform = "translateX(0)";
              activeSectionPanel = sectionPanel;
              activeSectionTrigger = sectionTrigger;
              restoredSectionPanel = sectionPanel;
            }
          }

          // Force layout flush, then restore transition durations after paint
          menuShell.offsetHeight;
          panel.offsetHeight;
          if (restoredSectionPanel) restoredSectionPanel.offsetHeight;

          window.requestAnimationFrame(() => {
            window.requestAnimationFrame(() => {
              menuShell.style.transitionDuration = "1000ms";
              panel.style.transitionDuration = "1000ms";
              if (restoredSectionPanel) {
                restoredSectionPanel.style.transitionDuration = "1000ms";
              }
            });
          });
        }

        // Clean the URL
        history.replaceState(null, "", "/");
      }
    }
  </script>
</BaseLayout>
