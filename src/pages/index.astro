---

<BaseLayout title="ISOv8®" description=" ">
  <main>
    <EngageContact />

    <section class="relative h-screen overflow-hidden">
      <header class="absolute inset-x-0 top-0 z-30">
        <a
          href="/"
          aria-label="ISO V8 home"
          class="absolute right-8 top-[15px] lg:hidden"
        >
          <img
            src="/assets/images/isov8-logo-mark.svg"
            alt="ISO V8"
            class="w-16"
          />
        </a>

        <a
          href="/"
          aria-label="ISO V8 home"
          class="absolute left-1/2 top-[15px] hidden -translate-x-1/2 lg:block"
        >
          <img
            src="/assets/images/isov8-logo.svg"
            alt="ISO V8"
            class="w-[300px] max-w-none"
          />
        </a>

        <div class="flex items-center justify-between gap-6 px-8 py-8 text-[20px] font-medium text-white lg:px-12 lg:py-10">
          <button
            id="menu-toggle"
            type="button"
            aria-controls="menu-shell"
            aria-expanded="false"
            aria-label="Open menu"
            class="flex cursor-pointer items-center gap-4 text-white transition-colors duration-300"
          >
            <span class="flex w-10 flex-col gap-3" aria-hidden="true">
              <span class="h-0.5 w-full bg-current"></span>
              <span class="h-0.5 w-7 bg-current"></span>
              <span class="h-0.5 w-4 bg-current"></span>
            </span>
            <span class="hidden lg:inline">MENU</span>
          </button>

          <nav aria-label="Primary" class="hidden items-center gap-6 lg:flex lg:gap-10">
            <a href="#about-us">ABOUT US</a>
            <a href="#inside-v8">INSIDE V8</a>
          </nav>
        </div>
      </header>

      <div
        id="menu-overlay"
        class="pointer-events-none fixed inset-0 z-[35] bg-black/50 opacity-0 transition-opacity ease-out"
        aria-hidden="true"
        style="transition-duration: 1000ms;"
      ></div>

      <div
        id="menu-shell"
        role="dialog"
        aria-modal="true"
        aria-label="Site navigation"
        inert
        class="pointer-events-none fixed inset-y-0 left-0 z-40 flex h-dvh transition-transform ease-out will-change-transform"
        style="transform: translateX(-100%); transition-duration: 1000ms;"
      >
        <nav
          id="menu-panel"
          aria-label="Main menu"
          class="relative z-10 h-dvh w-[250px] overflow-y-auto overscroll-contain border-r border-gray-300 bg-white max-[678px]:w-dvw"
          aria-hidden="true"
        >
          <button
            id="menu-close"
            type="button"
            aria-controls="menu-shell"
            aria-label="Close menu"
            class="absolute left-8 top-8 flex cursor-pointer items-center gap-4 text-[20px] font-medium text-black lg:left-12 lg:top-10"
          >
            <span class="relative flex h-10 w-10 items-center justify-center" aria-hidden="true">
              <span class="absolute h-0.5 w-full rotate-45 bg-current"></span>
              <span class="absolute h-0.5 w-full -rotate-45 bg-current"></span>
            </span>
            <span>CLOSE</span>
          </button>

          <div class="flex flex-col gap-6 px-8 pt-28 lg:px-12 lg:pt-32">
            {phases.map((phase) => (
              <button
                id={`menu-${phase.id}-trigger`}
                type="button"
                aria-controls={`menu-${phase.id}-panel`}
                aria-expanded="false"
                class="phase-trigger inline-block cursor-pointer text-left text-[18px] font-[400] leading-tight text-black transition-colors hover:text-[#088cbc] hover:underline"
              >
                {phase.label}
              </button>
            ))}
          </div>
        </nav>

        {phases.map((phase) => (
          <div
            id={`menu-${phase.id}-panel`}
            role="navigation"
            aria-label={phase.label}
            class="phase-panel pointer-events-none relative z-0 hidden h-dvh w-[350px] shrink-0 overflow-y-auto overscroll-contain border-r border-gray-300 bg-white transition-transform ease-out will-change-transform max-[678px]:absolute max-[678px]:inset-y-0 max-[678px]:left-0 max-[678px]:z-20 max-[678px]:w-dvw"
            aria-hidden="true"
            style="transform: translateX(-100%); transition-duration: 1000ms;"
          >
            <img
              src={phase.image}
              alt=""
              aria-hidden="true"
              class="mx-auto block h-[250px] w-[350px] object-cover max-[678px]:w-full"
            />

            <div class="mt-[50px] flex items-center gap-4 px-[45px]">
              <button
                id={`menu-${phase.id}-back`}
                type="button"
                aria-controls={`menu-${phase.id}-panel`}
                aria-label="Back to primary menu"
                class="phase-back flex h-5 w-5 shrink-0 cursor-pointer items-center justify-center text-black transition-colors hover:text-[#088cbc]"
              >
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M13 4L7 10L13 16"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>

              <p class="text-[20px] font-[500] leading-tight text-black">
                {phase.label}
              </p>
            </div>

            <div class="mt-[60px] flex flex-col gap-6 px-[45px] pb-12">
              {phase.sections.map((section) => (
                section.id === "base-platforms" ? (
                  <button
                    id="menu-articles-trigger"
                    type="button"
                    aria-controls="menu-articles-panel"
                    aria-expanded="false"
                    class="menu-articles-trigger inline-block cursor-pointer text-left text-[18px] font-[400] leading-tight text-black transition-colors hover:text-[#088cbc] hover:underline"
                  >
                    {section.label}
                  </button>
                ) : (
                  <p class="inline-block text-left text-[18px] font-[400] leading-tight text-[#999999]">
                    {section.label}
                  </p>
                )
              ))}
            </div>
          </div>
        ))}

        <div
          id="menu-articles-panel"
          role="navigation"
          aria-label="Base Platforms & Structural Principles"
          class="pointer-events-none relative -z-10 hidden h-dvh w-[350px] shrink-0 overflow-y-auto overscroll-contain border-r border-gray-300 bg-white transition-transform ease-out will-change-transform max-[678px]:absolute max-[678px]:inset-y-0 max-[678px]:left-0 max-[678px]:z-30 max-[678px]:w-dvw"
          aria-hidden="true"
          style="transform: translateX(-100%); transition-duration: 1000ms;"
        >
          <div class="mt-[50px] flex items-center gap-4 px-[45px]">
            <button
              id="menu-articles-back"
              type="button"
              aria-controls="menu-articles-panel"
              aria-label="Back to Phase 1 panel"
              class="flex h-5 w-5 shrink-0 cursor-pointer items-center justify-center text-black transition-colors hover:text-[#088cbc]"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M13 4L7 10L13 16"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>

            <p class="text-[20px] font-[500] leading-tight text-black">
              Base Platforms & Structural Principles
            </p>
          </div>

          <div class="mt-[60px] flex flex-col gap-6 px-[45px] pb-12">
            {
              structuralSidebarLinks.map((link) => (
                <a
                  href={link.href}
                  class="menu-tertiary-link inline-block cursor-pointer text-left text-[18px] font-[400] leading-tight text-black transition-colors hover:text-[#088cbc] hover:underline active:text-[#088cbc] active:underline"
                >
                  {link.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <video
        class="absolute inset-0 h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      >
        <source src="/assets/images/banner.mp4" type="video/mp4" />
      </video>

      <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-black/65 via-black/20 to-transparent lg:h-36"></div>

      <h1
        class="absolute bottom-8 left-8 z-20 text-[35px] font-[600] leading-[1.1] text-white lg:bottom-12 lg:left-12"
      >
        <span class="flex items-start gap-3">
          <img
            src="/assets/images/bullet-point.webp"
            alt=""
            aria-hidden="true"
            class="mt-1 h-7 w-auto shrink-0 object-contain"
          />
          <span>Shipping Container Conversions</span>
        </span>
        <span class="mt-1 flex items-start gap-3">
          <img
            src="/assets/images/bullet-point.webp"
            alt=""
            aria-hidden="true"
            class="mt-1 h-7 w-auto shrink-0 object-contain"
          />
          <span>Anti-Vandal Buildings</span>
        </span>
      </h1>
    </section>

    <section
      class="bg-cover bg-center bg-no-repeat px-6 py-12 lg:px-12"
      style="background-image: url('/assets/images/showcase-background.webp');"
    >
      <h2 class="text-center text-[35px] font-[600]">
        ISO Shipping Container Conversions for Businesses, Creatives &
        Commercial Sectors Across the UK
      </h2>

      <div class="mx-auto mt-10 grid w-[calc(100%-40px)] gap-x-4 gap-y-10 xl:w-[calc(100%-150px)] xl:grid-cols-2 xl:gap-y-6 xl:gap-x-6">
        {
          conversionImages.map((image) => (
            <article class="flex flex-col items-start gap-4 min-[679px]:flex-row">
              <img
                src={`/assets/images/${image.src}`}
                alt={image.title}
                class="h-auto w-[250px] shrink-0"
                loading="lazy"
              />

              <div class="flex-1">
                <h3 class="text-left text-[24px] font-[600] leading-tight text-[#1f1f1f]">
                  {image.title}
                </h3>
                <p class="mt-3 text-[16px] leading-[1.6] text-[#4b4b4b]">
                  {image.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <footer class="bg-[#f5f3ee]">
      <div class="border-y border-gray-300 px-6 py-14 lg:px-12 lg:py-12">
        <div class="mx-[75px] flex items-center justify-between gap-6 max-[1024px]:flex-col max-[1024px]:justify-center max-[1024px]:gap-10">
          <a href="/" aria-label="ISO V8 home">
            <img
              src="/assets/images/isov8-logo-colour.svg"
              alt="ISO V8"
              class="h-auto w-[300px] max-w-full"
            />
          </a>

          <p class="text-right text-[30px] font-[400] italic leading-none text-black max-[1024px]:text-center">
            without doubt&reg;
          </p>
        </div>
      </div>

      <div class="border-b border-gray-300 px-6 py-8 lg:px-12">
        <div class="mx-[75px] flex items-center justify-between gap-6 max-[1024px]:flex-col max-[1024px]:items-center max-[1024px]:gap-10">
          <p class="text-[16px] leading-none text-[#6f6f6f] max-[1024px]:text-center">
            &copy; 2025 ContainerKing&reg;. All rights reserved.
          </p>

          <nav aria-label="Footer policies" class="flex items-center gap-8 max-[1024px]:flex-row max-[1024px]:justify-center max-[1024px]:gap-8">
            <a href="/cookie-policy" class="text-[16px] leading-none text-[#6f6f6f] underline transition-colors hover:text-[#088cbc]">
              Cookie Policy
            </a>
            <a href="/privacy-policy" class="text-[16px] leading-none text-[#6f6f6f] underline transition-colors hover:text-[#088cbc]">
              Privacy Policy
            </a>
          </nav>
        </div>
      </div>
    </footer>
  </main>

  <style is:inline>
    .phase-trigger:active,
    .phase-trigger.is-pressed,
    .phase-trigger[aria-expanded="true"] {
      color: #088cbc;
      text-decoration: underline;
    }

    .menu-articles-trigger:active,
    .menu-articles-trigger.is-pressed,
    .menu-articles-trigger[aria-expanded="true"] {
      color: #088cbc;
      text-decoration: underline;
    }

    .menu-secondary-link:active,
    .menu-secondary-link.is-pressed,
    .menu-tertiary-link:active,
    .menu-tertiary-link.is-pressed {
      color: #088cbc;
      text-decoration: underline;
    }
  </style>

  <script is:inline>
    const menuToggle = document.getElementById("menu-toggle");
    const menuOverlay = document.getElementById("menu-overlay");
    const menuShell = document.getElementById("menu-shell");
    const menuPanel = document.getElementById("menu-panel");
    const menuClose = document.getElementById("menu-close");

    const phaseTriggers = document.querySelectorAll(".phase-trigger");
    const phasePanels = document.querySelectorAll(".phase-panel");
    const phaseBackButtons = document.querySelectorAll(".phase-back");

    const menuArticlesTrigger = document.getElementById("menu-articles-trigger");
    const menuArticlesBack = document.getElementById("menu-articles-back");
    const menuArticlesPanel = document.getElementById("menu-articles-panel");

    let lockedScrollY = 0;
    let pageLockCount = 0;

    const lockPageScroll = () => {
      if (pageLockCount === 0) {
        lockedScrollY = window.scrollY;
        document.documentElement.style.overflow = "hidden";
        document.body.style.position = "fixed";
        document.body.style.top = `-${lockedScrollY}px`;
        document.body.style.left = "0";
        document.body.style.right = "0";
        document.body.style.width = "100%";
        document.body.style.overflow = "hidden";
      }

      pageLockCount += 1;
    };

    const unlockPageScroll = () => {
      if (pageLockCount === 0) {
        return;
      }

      pageLockCount -= 1;

      if (pageLockCount > 0) {
        return;
      }

      document.documentElement.style.removeProperty("overflow");
      document.body.style.removeProperty("position");
      document.body.style.removeProperty("top");
      document.body.style.removeProperty("left");
      document.body.style.removeProperty("right");
      document.body.style.removeProperty("width");
      document.body.style.removeProperty("overflow");
      window.scrollTo(0, lockedScrollY);
    };

    if (menuToggle && menuOverlay && menuShell && menuPanel && menuClose) {
      let isMenuAnimating = false;
      let isPhaseAnimating = false;
      let isArticlesAnimating = false;
      let isSwitchingPhase = false;
      let activePhasePanel = null;
      let activePhaseTrigger = null;

      const isMenuOpen = () => menuToggle.getAttribute("aria-expanded") === "true";
      const isPhasePanelOpen = () => activePhasePanel !== null;
      const isArticlesPanelOpen = () =>
        menuArticlesTrigger?.getAttribute("aria-expanded") === "true";

      const syncMenuInteractivity = () => {
        const menuIsOpen = isMenuOpen();
        menuShell.style.pointerEvents = menuIsOpen ? "auto" : "none";
        if (menuIsOpen) {
          menuShell.removeAttribute("inert");
        } else {
          menuShell.setAttribute("inert", "");
        }
      };

      const setMenuShellTransform = (isOpen) => {
        menuShell.style.transform = isOpen ? "translateX(0)" : "translateX(-100%)";
      };

      const resetArticlesPanelState = () => {
        if (!menuArticlesTrigger || !menuArticlesPanel) {
          return;
        }

        menuArticlesTrigger.setAttribute("aria-expanded", "false");
        menuArticlesPanel.setAttribute("aria-hidden", "true");
        menuArticlesPanel.classList.add("hidden");
        menuArticlesPanel.classList.add("pointer-events-none");
        menuArticlesPanel.classList.remove("pointer-events-auto");
        menuArticlesPanel.style.transform = "translateX(-100%)";
        menuArticlesPanel.style.removeProperty("z-index");
      };

      const resetAllPhasePanels = () => {
        phaseTriggers.forEach((trigger) => {
          trigger.setAttribute("aria-expanded", "false");
        });

        phasePanels.forEach((panel) => {
          panel.setAttribute("aria-hidden", "true");
          panel.classList.add("hidden");
          panel.classList.add("pointer-events-none");
          panel.classList.remove("pointer-events-auto");
          panel.style.transform = "translateX(-100%)";
        });

        resetArticlesPanelState();
        activePhasePanel = null;
        activePhaseTrigger = null;
      };

      const finishArticlesTransition = () => {
        if (!isArticlesAnimating) {
          return;
        }

        isArticlesAnimating = false;

        if (menuArticlesPanel?.getAttribute("aria-hidden") === "true") {
          menuArticlesPanel.classList.add("hidden");
        }

        syncMenuInteractivity();
      };

      const resetSinglePhasePanel = (trigger, panel) => {
        if (!trigger || !panel) {
          return;
        }

        trigger.setAttribute("aria-expanded", "false");
        panel.setAttribute("aria-hidden", "true");
        panel.classList.add("hidden");
        panel.classList.add("pointer-events-none");
        panel.classList.remove("pointer-events-auto");
        panel.style.transitionDuration = "0s";
        panel.style.transform = "translateX(-100%)";
        panel.offsetHeight;
        panel.style.transitionDuration = "1000ms";

        activePhasePanel = null;
        activePhaseTrigger = null;
      };

      const switchPhasePanel = (newTrigger, newPanel) => {
        if (!activePhasePanel || !activePhaseTrigger) {
          return;
        }

        if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase) {
          return;
        }

        const oldPanel = activePhasePanel;
        const oldTrigger = activePhaseTrigger;
        const articlesWasOpen = isArticlesPanelOpen();

        isSwitchingPhase = true;
        isPhaseAnimating = true;

        const slideDistance = (oldPanel.offsetWidth + (menuArticlesPanel && articlesWasOpen ? menuArticlesPanel.offsetWidth : 0)) + "px";

        if (menuArticlesPanel && articlesWasOpen) {
          menuArticlesTrigger?.setAttribute("aria-expanded", "false");
          menuArticlesPanel.setAttribute("aria-hidden", "true");
          menuArticlesPanel.classList.add("pointer-events-none");
          menuArticlesPanel.classList.remove("pointer-events-auto");
          menuArticlesPanel.style.transform = "translateX(-" + slideDistance + ")";
        }

        oldTrigger.setAttribute("aria-expanded", "false");
        oldPanel.setAttribute("aria-hidden", "true");
        oldPanel.classList.add("pointer-events-none");
        oldPanel.classList.remove("pointer-events-auto");
        oldPanel.style.transform = "translateX(-" + slideDistance + ")";

        activePhasePanel = null;
        activePhaseTrigger = null;

        if (menuToggle.getAttribute("aria-expanded") === "true") {
          setMenuShellTransform(true);
        }

        let handled = false;
        const proceed = () => {
          if (handled) {
            return;
          }
          handled = true;

          isPhaseAnimating = false;
          isSwitchingPhase = false;
          oldPanel.classList.add("hidden");

          if (menuArticlesPanel && articlesWasOpen) {
            menuArticlesPanel.classList.add("hidden");
            menuArticlesPanel.style.removeProperty("z-index");
            menuArticlesPanel.style.transitionDuration = "0s";
            menuArticlesPanel.style.transform = "translateX(-100%)";
            menuArticlesPanel.offsetHeight;
            menuArticlesPanel.style.transitionDuration = "1000ms";
          }

          oldPanel.style.transitionDuration = "0s";
          oldPanel.style.transform = "translateX(-100%)";
          oldPanel.offsetHeight;
          oldPanel.style.transitionDuration = "1000ms";

          window.requestAnimationFrame(() => {
            setPhasePanelState(newTrigger, newPanel, true);
          });
        };

        oldPanel.addEventListener("transitionend", (e) => {
          if (e.propertyName === "transform") {
            proceed();
          }
        }, { once: true });

        setTimeout(proceed, 1100);
      };

      const finishPhaseTransition = () => {
        if (!isPhaseAnimating) {
          return;
        }

        isPhaseAnimating = false;

        phasePanels.forEach((panel) => {
          if (panel.getAttribute("aria-hidden") === "true") {
            panel.classList.add("hidden");
          }
        });

        if (menuArticlesPanel?.getAttribute("aria-hidden") === "true") {
          menuArticlesPanel.classList.add("hidden");
        }

        syncMenuInteractivity();
      };

      const setArticlesPanelState = (isOpen) => {
        if (!menuArticlesTrigger || !menuArticlesPanel) {
          return;
        }

        const currentIsOpen = isArticlesPanelOpen();
        if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase || currentIsOpen === isOpen) {
          return;
        }

        isArticlesAnimating = true;
        menuArticlesTrigger.setAttribute("aria-expanded", String(isOpen));
        menuArticlesPanel.setAttribute("aria-hidden", String(!isOpen));
        syncMenuInteractivity();

        if (isOpen) {
          menuArticlesPanel.style.transform = "translateX(-100%)";
          menuArticlesPanel.classList.remove("hidden");

          window.requestAnimationFrame(() => {
            menuArticlesPanel.classList.remove("pointer-events-none");
            menuArticlesPanel.classList.add("pointer-events-auto");
            menuArticlesPanel.style.transform = "translateX(0)";
            if (menuToggle.getAttribute("aria-expanded") === "true") {
              setMenuShellTransform(true);
            }
          });

          return;
        }

        menuArticlesPanel.classList.add("pointer-events-none");
        menuArticlesPanel.classList.remove("pointer-events-auto");
        menuArticlesPanel.style.transform = "translateX(-100%)";

        if (menuToggle.getAttribute("aria-expanded") === "true") {
          setMenuShellTransform(true);
        }
      };

      const setPhasePanelState = (trigger, panel, isOpen) => {
        if (!trigger || !panel) {
          return;
        }

        const currentIsOpen = trigger.getAttribute("aria-expanded") === "true";
        if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase || currentIsOpen === isOpen) {
          return;
        }

        isPhaseAnimating = true;
        trigger.setAttribute("aria-expanded", String(isOpen));
        panel.setAttribute("aria-hidden", String(!isOpen));
        syncMenuInteractivity();

        if (isOpen) {
          activePhasePanel = panel;
          activePhaseTrigger = trigger;
          panel.style.transform = "translateX(-100%)";
          panel.classList.remove("hidden");

          window.requestAnimationFrame(() => {
            panel.classList.remove("pointer-events-none");
            panel.classList.add("pointer-events-auto");
            panel.style.transform = "translateX(0)";
            if (menuToggle.getAttribute("aria-expanded") === "true") {
              setMenuShellTransform(true);
            }
          });

          return;
        }

        panel.classList.add("pointer-events-none");
        panel.classList.remove("pointer-events-auto");
        panel.style.transform = "translateX(-100%)";
        activePhasePanel = null;
        activePhaseTrigger = null;

        if (menuToggle.getAttribute("aria-expanded") === "true") {
          setMenuShellTransform(true);
        }
      };

      const setMenuState = (isOpen) => {
        menuToggle.setAttribute("aria-expanded", String(isOpen));
        menuOverlay.setAttribute("aria-hidden", String(!isOpen));
        menuPanel.setAttribute("aria-hidden", String(!isOpen));
        menuOverlay.classList.toggle("opacity-0", !isOpen);
        menuOverlay.classList.toggle("opacity-100", isOpen);
        setMenuShellTransform(isOpen);

        if (!isOpen) {
          phaseTriggers.forEach((trigger) => {
            trigger.setAttribute("aria-expanded", "false");
          });
          phasePanels.forEach((panel) => {
            panel.classList.add("pointer-events-none");
            panel.classList.remove("pointer-events-auto");
          });
        }

        syncMenuInteractivity();
      };

      const finishMenuTransition = () => {
        if (!isMenuAnimating) {
          return;
        }

        isMenuAnimating = false;
        const isOpen = isMenuOpen();
        menuOverlay.classList.toggle("pointer-events-none", !isOpen);
        menuOverlay.classList.toggle("pointer-events-auto", isOpen);
        if (!isOpen) {
          resetAllPhasePanels();
          unlockPageScroll();
        }
        syncMenuInteractivity();
      };

      const requestMenuState = (nextIsOpen) => {
        const currentIsOpen = isMenuOpen();
        if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase || currentIsOpen === nextIsOpen) {
          return;
        }

        isMenuAnimating = true;
        menuOverlay.classList.remove("pointer-events-none");
        menuOverlay.classList.add("pointer-events-auto");
        if (nextIsOpen) {
          lockPageScroll();
        }
        setMenuState(nextIsOpen);
      };

      const trapFocus = (event) => {
        let focusPanel;
        if (isArticlesPanelOpen()) {
          focusPanel = menuArticlesPanel;
        } else if (isPhasePanelOpen()) {
          focusPanel = activePhasePanel;
        } else {
          focusPanel = menuPanel;
        }

        const focusableElements = focusPanel.querySelectorAll(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );

        if (focusableElements.length === 0) {
          return;
        }

        const firstFocusable = focusableElements[0];
        const lastFocusable = focusableElements[focusableElements.length - 1];

        if (event.shiftKey && document.activeElement === firstFocusable) {
          event.preventDefault();
          lastFocusable.focus();
        } else if (!event.shiftKey && document.activeElement === lastFocusable) {
          event.preventDefault();
          firstFocusable.focus();
        }
      };

      menuToggle.addEventListener("click", () => {
        requestMenuState(true);
        menuClose.focus();
      });

      menuClose.addEventListener("click", () => {
        requestMenuState(false);
        menuToggle.focus();
      });

      menuOverlay.addEventListener("click", () => {
        requestMenuState(false);
        menuToggle.focus();
      });

      document.addEventListener("keydown", (event) => {
        if (!isMenuOpen()) {
          return;
        }

        if (event.key === "Escape") {
          event.preventDefault();
          if (isArticlesPanelOpen()) {
            setArticlesPanelState(false);
          } else if (isPhasePanelOpen()) {
            setPhasePanelState(activePhaseTrigger, activePhasePanel, false);
          } else {
            requestMenuState(false);
            menuToggle.focus();
          }
        }

        if (event.key === "Tab") {
          trapFocus(event);
        }
      });

      phaseTriggers.forEach((trigger) => {
        const panelId = trigger.getAttribute("aria-controls");
        const panel = document.getElementById(panelId);

        if (panel) {
          trigger.addEventListener("click", () => {
            const isOpen = trigger.getAttribute("aria-expanded") === "true";

            if (!isOpen && activePhasePanel && activePhasePanel !== panel) {
              switchPhasePanel(trigger, panel);
              return;
            }

            setPhasePanelState(trigger, panel, !isOpen);
          });
        }
      });

      phaseBackButtons.forEach((backBtn) => {
        backBtn.addEventListener("click", () => {
          if (isMenuAnimating || isPhaseAnimating || isArticlesAnimating || isSwitchingPhase) {
            return;
          }

          const panel = backBtn.closest(".phase-panel");
          const trigger = document.getElementById(panel.id.replace("-panel", "-trigger"));

          isPhaseAnimating = true;

          const slideDistance = (panel.offsetWidth + (menuArticlesPanel && isArticlesPanelOpen() ? menuArticlesPanel.offsetWidth : 0)) + "px";

          if (menuArticlesPanel && isArticlesPanelOpen()) {
            menuArticlesTrigger?.setAttribute("aria-expanded", "false");
            menuArticlesPanel.setAttribute("aria-hidden", "true");
            menuArticlesPanel.classList.add("pointer-events-none");
            menuArticlesPanel.classList.remove("pointer-events-auto");
            menuArticlesPanel.style.transform = "translateX(-" + slideDistance + ")";
          }

          trigger?.setAttribute("aria-expanded", "false");
          panel.setAttribute("aria-hidden", "true");
          panel.classList.add("pointer-events-none");
          panel.classList.remove("pointer-events-auto");
          panel.style.transform = "translateX(-" + slideDistance + ")";

          activePhasePanel = null;
          activePhaseTrigger = null;

          if (menuToggle.getAttribute("aria-expanded") === "true") {
            setMenuShellTransform(true);
          }
        });
      });

      if (menuArticlesTrigger && menuArticlesPanel) {
        menuArticlesTrigger.addEventListener("click", () => {
          const isOpen =
            menuArticlesTrigger.getAttribute("aria-expanded") === "true";

          setArticlesPanelState(!isOpen);
        });
      }

      if (menuArticlesBack) {
        menuArticlesBack.addEventListener("click", () => {
          setArticlesPanelState(false);
        });
      }

      menuShell.addEventListener("touchstart", (event) => {
        const target = event.target.closest(
          ".phase-trigger, .menu-articles-trigger, .menu-secondary-link, .menu-tertiary-link"
        );
        if (target) target.classList.add("is-pressed");
      }, { passive: true });

      menuShell.addEventListener("touchend", (event) => {
        const pressed = menuShell.querySelector(".is-pressed");
        if (pressed) pressed.classList.remove("is-pressed");
      });

      menuShell.addEventListener("touchcancel", () => {
        const pressed = menuShell.querySelector(".is-pressed");
        if (pressed) pressed.classList.remove("is-pressed");
      });

      menuShell.addEventListener("transitionend", (event) => {
        if (event.propertyName === "transform" && isMenuAnimating) {
          finishMenuTransition();
        }
      });

      phasePanels.forEach((panel) => {
        panel.addEventListener("transitionend", (event) => {
          if (event.propertyName === "transform" && isPhaseAnimating) {
            finishPhaseTransition();
          }
        });
      });

      if (menuArticlesPanel) {
        menuArticlesPanel.addEventListener("transitionend", (event) => {
          if (event.propertyName === "transform" && isArticlesAnimating) {
            finishArticlesTransition();
          }
        });
      }
    }
  </script>
</BaseLayout>
