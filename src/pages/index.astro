---
import BaseLayout from "../layouts/BaseLayout.astro";

const conversionImages = [
  {
    src: "airbnb-pod.webp",
    title: "Airbnb Pods",
    description: "Stand out and earn more. Our bespoke container Airbnb pods can be styled for wow-factor—compact, comfortable, and unforgettable. Ideal for short stays, guest retreats, or off-grid escapes. Eye-catching, insulated and made to impress - ready to explore high-impact pods with serious rental appeal."
  },
  {
    src: "art-studio.webp",
    title: "Arts, Crafts, Hobbyists Studios",
    description: "Space to focus, freedom to create. Our bespoke container studios can be designed for artists, makers and hobbyists who need room to think and time to make. Bright, secure and insulated for year-round comfort. Whether it's painting, sewing, or sculpting: ready to create your own custom craft space?"
  },
  {
    src: "play-room.webp",
    title: "BDSM Play Rooms",
    description: "Privacy. Control. Atmosphere. Our bespoke container conversions can be transformed into fully private BDSM playrooms: sound-insulated, secure, and built to your preferences. Create a space that feels safe, personal, and entirely yours - ready to explore discreet, made-to-measure playroom options?"
  },
  {
    src: "canteen.webp",
    title: "Canteens",
    description: "Break time, built better. Our canteen and mess cabin conversions can be fitted out for comfort and durability - bright, easy to clean and ready for site life. Ideal for staff meals, rest breaks or shelter from the weather. Built tough, finished smart - uncover ready-to-use break room solutions."
  },
  {
    src: "cinema-room.webp",
    title: "Cinema Rooms",
    description: "Bring the big screen home. Our container cinema rooms can be crafted for pure escapism - dark, quiet and acoustically treated. Perfect for film buffs, directors, or anyone who takes movie nights seriously. Designed for atmosphere, built for comfort - find more details on your bespoke private cinema room."
  },
  {
    src: "classroom.webp",
    title: "Classrooms",
    description: "Teach in peace. Our container classrooms can be designed for calm, focused learning - quiet, warm and free from outside distractions: ideal for one-to-one tuition, small groups or online learning. A smarter, faster alternative to traditional builds - delve into bespoke classroom spaces that work."
  },
  {
    src: "craft-studio.webp",
    title: "Craft Studios",
    description: "Create without compromise. Our container craft studios can be tailored to your flow - bright, warm and distraction-free. Whether you're painting, stitching, sculpting or designing, this is your dedicated space to focus and flourish. Inspiring, secure and built around you. Navigate to your made-to-measure studio now."
  },
  {
    src: "gaming-room.webp",
    title: "Gaming Rooms",
    description: "Level up your setup. Our container gaming rooms can be styled for total immersion - dark walls, ambient lighting and zero distractions. Built for streamers, creators and serious players who want their own private world. Bold, atmospheric, and made to order. Discover your custom-built game zone now."
  },
  {
    src: "garden-room.webp",
    title: "Garden Rooms",
    description: "Not your average garden room. Our container conversions blend modern design with practical performance - think clean lines, sleek finishes and fully insulated comfort. Ideal for creative spaces, studios or home offices. Made to impress, made to last - investigate our designer garden rooms now."
  },
  {
    src: "gym.webp",
    title: "Gyms",
    description: "Train hard. Build smart. Our bespoke steel gym buildings and container gym conversions are built to take a beating - just like you. Fully insulated, ventilated and ready for kit. Ideal for PTs, sports clubs or home setups. Durable, relocatable and made to spec - why not examine your gym built the industrial way?"
  },
  {
    src: "insulated-storage.webp",
    title: "Insulated Storage",
    description: "Need more than just a basic box? Our lined and insulated storage containers offer dry, secure and temperature-stable space all year round. Perfect for tools, stock, equipment or sensitive items. Clean, ready-to-use and customisable. Discover a smarter way to store - tick box, explore our range now."
  },
  {
    src: "bar.webp",
    title: "Luxury Bars & Lounges",
    description: "Designed to impress. Built to perform. Our luxury container bars and lounges can be styled with fitted bars, ambient lighting, luxe finishes and serious atmosphere. Ideal for bold private builds or standout brand launches - tune in & cheque out our high-spec spaces that turn heads."
  },
  {
    src: "office.webp",
    title: "Luxury Offices",
    description: "Portable prestige. Built to impress. Our luxury container offices can be tailored with premium finishes, smart layouts and executive detail. Designed for entrepreneurs, directors and decision-makers who want more than just a workspace. Built to command respect from day one. Make it yours now."
  },
  {
    src: "home.webp",
    title: "Man Caves",
    description: "Your space. Your rules. Our bespoke man cave container conversions can be tailored for downtime, hobbies or serious-big screen time. Dark, bold, built around you: whether it's music, motors, gambling or just relaxing. Hard drinks, harder playlists. Peruse the ultimate retreat on your terms now."
  },
  {
    src: "meeting-room.webp",
    title: "Meeting Rooms",
    description: "Boardroom brains in a Box. Why settle for noise, glare or distraction? ISOv8® meeting rooms are acoustically treated, soundproofed and made for high-focus thinking. Perfect for strategy, deals or zoom meetings that matter. We build bespoke, relocatable meeting spaces that perform - and impress - smart, private: built for serious business."
  },
  {
    src: "motorsport-garage.webp",
    title: "Motorsport Garages",
    description: "Smart garages for petrolheads. Your own pit lane in a box. Space for classics, karts or just track-day toys: plus room to work and for benches, cabinets and spares. IsoV8® builds wide-body anti-vandal workshops with grease, grit and gearstick glory. Space to polish, tinker and enjoy. Made for weekends, wheel nuts and winners. built with dream team energy."
  },
  {
    src: "retail-popup-shop.webp",
    title: "Retail Pop-Up Shops",
    description: "Pop-Up shops that scream style. Bold, branded and impossible to ignore - these container conversions aren't just shops, they're show-stoppers. From artisan espresso bars to streetwear temples, we build mobile spaces that demand attention. Perfect for festivals, high streets, markets and brand pioneers. you bring the vision — we'll build the buzz."
  },
  {
    src: "she-shed.webp",
    title: "She Sheds",
    description: "A Containerised She Shed! Girl power in a box: and no, he's not invited. Fully-insulated, electrified and 100% yours. She Shed container conversions built for peace, pampering or plotting your empire. Art studio? Yoga pod? Wine & whinge den? You choose. Built your way, delivered UK-wide. No men - no boys!"
  },
  {
    src: "site-office.webp",
    title: "Site Offices",
    description: "Steel-built, site-ready, lined & insulated offices: anti-vandal, secure, portable and made for serious work. We convert shipping containers and fabricate steel site offices, to order. You choose electrics, heating, lighting, layout and internal finishes. Ideal for construction, logistics, manufacturing, and remote teams. Built to your spec - delivered nationwide."
  },
  {
    src: "workshop.webp",
    title: "Workshops",
    description: "Workshops that mean business. Steel-built, badged-up and ready to graft. From greasy spanners to sparks and sawdust, these converted container workshops are made to take the hits and keep working. Fit them with benches, racks, power, light and grit. Built for mechanics, makers, engineers and repair crews - bespoke customised relocatable: all yours."
  }
];
---

<BaseLayout title="ISOv8®" description=" ">
  <main>
    <button
      id="engage-button"
      type="button"
      class="engage-button fixed bottom-6 right-6 z-30 flex h-[125px] w-[125px] cursor-pointer items-center justify-center rounded-full bg-transparent p-0 max-[768px]:hidden max-[640px]:bottom-4 max-[640px]:right-4"
      aria-controls="contact-modal"
      aria-expanded="false"
    >
      <svg
        class="engage-button__ring absolute inset-0 h-full w-full -rotate-90"
        viewBox="0 0 125 125"
        aria-hidden="true"
      >
        <circle
          class="engage-button__ring-base"
          cx="62.5"
          cy="62.5"
          r="60"
          pathLength="100"
        />
        <circle
          class="engage-button__ring-progress"
          cx="62.5"
          cy="62.5"
          r="60"
          pathLength="100"
        />
      </svg>
      <div class="relative z-10 flex h-[105px] w-[105px] flex-col items-center justify-center rounded-full bg-white">
        <span class="h-[3px] w-[82px] bg-[#088cbc]"></span>
        <span class="my-2 text-[20px] font-[600] leading-none text-black">ENGAGE</span>
        <span class="h-[3px] w-[82px] bg-[#088cbc]"></span>
      </div>
    </button>

    <div
      id="contact-overlay"
      class="pointer-events-none fixed inset-0 z-[45] bg-black/70 opacity-0 transition-opacity ease-out"
      aria-hidden="true"
      style="transition-duration: 1000ms;"
    ></div>

    <div
      id="contact-modal"
      class="pointer-events-none fixed inset-0 z-50 flex items-center justify-center px-6 opacity-0 transition-opacity ease-out"
      aria-hidden="true"
      style="transition-duration: 1000ms;"
    >
      <button
        id="contact-close"
        type="button"
        aria-controls="contact-modal"
        aria-expanded="false"
        class="absolute left-16 top-16 flex cursor-pointer items-center text-white lg:left-20 lg:top-20"
      >
        <span class="relative flex h-10 w-10 items-center justify-center" aria-hidden="true">
          <span class="absolute h-0.5 w-full rotate-45 bg-current"></span>
          <span class="absolute h-0.5 w-full -rotate-45 bg-current"></span>
        </span>
      </button>

      <div class="relative w-full max-w-[min(94vw,1100px)]">
        <img
          src="/assets/images/contact-background.svg"
          alt=""
          aria-hidden="true"
          class="h-auto max-h-[calc(100dvh-72px)] w-full"
        />

        <form
          id="contact-form"
          novalidate
          class="absolute inset-0 flex items-center justify-center px-8 py-8 text-black lg:px-20 lg:py-10"
        >
          <div class="w-full max-w-[760px]">
            <div class="mb-7 flex items-center justify-between gap-6">
              <div class="flex items-center gap-3">
                <h3 class="text-[40px] font-[600] leading-none text-black">Just As</h3>
                <a href="/" aria-label="ISO V8 home">
                  <img
                    src="/assets/images/container-king-logo-mark-colour.svg"
                    alt="Container King"
                    class="-ml-1 h-9 w-auto"
                  />
                </a>
              </div>

              <a
                href="tel:01724870000"
                class="text-[28px] font-[600] leading-none text-[#088cbc] transition-opacity hover:opacity-80"
              >
                01724 870000
              </a>
            </div>

            <div class="grid gap-2 md:grid-cols-2 lg:gap-3">
              <div class="flex flex-col gap-1">
                <input
                  type="text"
                  name="name"
                  aria-label="Name"
                  placeholder="Name"
                  autocomplete="name"
                  required
                  maxlength="80"
                  data-contact-input
                  class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[16px] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus:border-[#088cbc]"
                />
                <p
                  data-error-for="name"
                  class="min-h-[16px] text-[12px] leading-tight text-[#c53d32]"
                ></p>
              </div>

              <div class="flex flex-col gap-1">
                <input
                  type="text"
                  name="telephone"
                  aria-label="Telephone Number"
                  placeholder="Telephone Number"
                  autocomplete="tel"
                  inputmode="numeric"
                  required
                  pattern="^[0-9]{7,15}$"
                  data-contact-input
                  class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[16px] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus:border-[#088cbc]"
                />
                <p
                  data-error-for="telephone"
                  class="min-h-[16px] text-[12px] leading-tight text-[#c53d32]"
                ></p>
              </div>

              <div class="flex flex-col gap-1 md:col-span-2">
                <input
                  type="text"
                  name="business-name"
                  aria-label="Business Name"
                  placeholder="Business Name"
                  autocomplete="organization"
                  required
                  maxlength="100"
                  data-contact-input
                  class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[16px] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus:border-[#088cbc]"
                />
                <p
                  data-error-for="business-name"
                  class="min-h-[16px] text-[12px] leading-tight text-[#c53d32]"
                ></p>
              </div>

              <div class="flex flex-col gap-1 md:col-span-2">
                <textarea
                  name="enquiry-details"
                  rows="5"
                  aria-label="Enquiry Details"
                  placeholder="Enquiry Details"
                  required
                  maxlength="1000"
                  data-contact-input
                  class="w-full resize-none rounded-[6px] border border-gray-300 bg-white px-4 py-3 text-[16px] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus:border-[#088cbc]"
                ></textarea>
                <p
                  data-error-for="enquiry-details"
                  class="min-h-[16px] text-[12px] leading-tight text-[#c53d32]"
                ></p>
              </div>
            </div>

            <button
              type="submit"
              class="mt-3 h-12 w-full cursor-pointer rounded-[6px] bg-[#088cbc] px-8 text-[16px] font-[600] leading-none text-white transition-opacity hover:opacity-90"
            >
              Submit
            </button>
          </div>
        </form>
      </div>
    </div>

    <section class="relative h-screen overflow-hidden">
      <header class="absolute inset-x-0 top-0 z-30">
        <a
          href="/"
          aria-label="ISO V8 home"
          class="absolute right-8 top-[15px] lg:hidden"
        >
          <img
            src="/assets/images/isov8-logo-mark.svg"
            alt="ISO V8"
            class="w-16"
          />
        </a>

        <a
          href="/"
          aria-label="ISO V8 home"
          class="absolute left-1/2 top-[15px] hidden -translate-x-1/2 lg:block"
        >
          <img
            src="/assets/images/isov8-logo.svg"
            alt="ISO V8"
            class="w-[300px] max-w-none"
          />
        </a>

        <div class="flex items-center justify-between gap-6 px-8 py-8 text-[20px] font-medium text-white lg:px-12 lg:py-10">
          <button
            id="menu-toggle"
            type="button"
            aria-controls="menu-panel"
            aria-expanded="false"
            class="flex cursor-pointer items-center gap-4 text-white transition-colors duration-300"
          >
            <span class="flex w-10 flex-col gap-3" aria-hidden="true">
              <span class="h-0.5 w-full bg-current"></span>
              <span class="h-0.5 w-7 bg-current"></span>
              <span class="h-0.5 w-4 bg-current"></span>
            </span>
            <span class="hidden lg:inline">MENU</span>
          </button>

          <nav aria-label="Primary" class="hidden items-center gap-6 lg:flex lg:gap-10">
            <a href="#about-us">ABOUT US</a>
            <a href="#inside-v8">INSIDE V8</a>
          </nav>
        </div>
      </header>

      <div
        id="menu-overlay"
        class="pointer-events-none fixed inset-0 z-[35] bg-black/50 opacity-0 transition-opacity ease-out"
        aria-hidden="true"
        style="transition-duration: 1000ms;"
      ></div>

      <div
        id="menu-shell"
        class="pointer-events-none fixed inset-y-0 left-0 z-40 flex h-dvh transition-transform ease-out"
        style="transform: translateX(-100%); transition-duration: 1000ms;"
      >
        <div
          id="menu-panel"
          class="relative z-10 h-dvh w-[250px] overflow-y-auto overscroll-contain border-r border-gray-300 bg-white max-[678px]:w-dvw"
          aria-hidden="true"
        >
          <button
            id="menu-close"
            type="button"
            aria-controls="menu-panel"
            aria-expanded="false"
            class="absolute left-8 top-8 flex cursor-pointer items-center gap-4 text-[20px] font-medium text-black lg:left-12 lg:top-10"
          >
            <span class="relative flex h-10 w-10 items-center justify-center" aria-hidden="true">
              <span class="absolute h-0.5 w-full rotate-45 bg-current"></span>
              <span class="absolute h-0.5 w-full -rotate-45 bg-current"></span>
            </span>
            <span>CLOSE</span>
          </button>

          <div class="px-8 pt-28 lg:px-12 lg:pt-32">
            <button
              id="menu-base-platforms-trigger"
              type="button"
              aria-controls="menu-base-platforms-panel"
              aria-expanded="false"
              class="menu-base-platforms-trigger inline-block cursor-pointer text-left text-[18px] font-[400] leading-tight text-black transition-colors hover:text-[#088cbc] hover:underline"
            >
              Base Platforms &amp; Structural Principles
            </button>
          </div>
        </div>

        <div
          id="menu-base-platforms-panel"
          class="pointer-events-none relative z-0 hidden h-dvh w-[350px] shrink-0 border-r border-gray-300 bg-white transition-transform ease-out max-[678px]:absolute max-[678px]:inset-y-0 max-[678px]:left-0 max-[678px]:z-20 max-[678px]:w-dvw"
          aria-hidden="true"
          style="transform: translateX(-100%); transition-duration: 1000ms;"
        >
          <img
            src="/assets/images/sidebar-placeholder.webp"
            alt=""
            aria-hidden="true"
            class="block w-full"
          />

          <div class="mt-[50px] flex items-center gap-4 px-[45px]">
            <button
              id="menu-base-platforms-back"
              type="button"
              aria-controls="menu-base-platforms-panel"
              aria-label="Back to primary menu"
              class="flex h-5 w-5 shrink-0 cursor-pointer items-center justify-center text-black"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M13 4L7 10L13 16"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>

            <p class="text-[20px] font-[500] leading-tight text-black">
              Base Platforms &amp; Structural Principles
            </p>
          </div>

          <a
            id="menu-structural-hub-link"
            href="/structural-platforms-hub"
            class="menu-secondary-link mt-[60px] inline-block cursor-pointer px-[45px] text-left text-[18px] font-[400] leading-tight text-black transition-colors hover:text-[#088cbc] hover:underline"
          >
            Hub Page - Understanding the Structural Platforms Behind Container Conversions and Steel Anti-Vandal Buildings
          </a>
        </div>
      </div>

      <video
        class="absolute inset-0 h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      >
        <source src="/assets/images/banner.mp4" type="video/mp4" />
      </video>

      <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-black/65 via-black/20 to-transparent lg:h-36"></div>

      <h1
        class="absolute bottom-8 left-8 z-20 text-[35px] font-[600] leading-[1.1] text-white lg:bottom-12 lg:left-12"
      >
        <span class="flex items-start gap-3">
          <img
            src="/assets/images/bullet-point.webp"
            alt=""
            aria-hidden="true"
            class="mt-1 h-7 w-auto shrink-0 object-contain"
          />
          <span>Shipping Container Conversions</span>
        </span>
        <span class="mt-1 flex items-start gap-3">
          <img
            src="/assets/images/bullet-point.webp"
            alt=""
            aria-hidden="true"
            class="mt-1 h-7 w-auto shrink-0 object-contain"
          />
          <span>Anti-Vandal Buildings</span>
        </span>
      </h1>
    </section>

    <section
      class="bg-cover bg-center bg-no-repeat px-6 py-12 lg:px-12"
      style="background-image: url('/assets/images/showcase-background.webp');"
    >
      <h2 class="text-center text-[35px] font-[600]">
        ISO Shipping Container Conversions for Businesses, Creatives &
        Commercial Sectors Across the UK
      </h2>

      <div class="mx-auto mt-10 grid w-[calc(100%-40px)] gap-x-4 gap-y-10 xl:w-[calc(100%-150px)] xl:grid-cols-2 xl:gap-y-6 xl:gap-x-6">
        {
          conversionImages.map((image) => (
            <article class="flex flex-col items-start gap-4 min-[679px]:flex-row">
              <img
                src={`/assets/images/${image.src}`}
                alt={image.title}
                class="h-auto w-[250px] shrink-0"
                loading="lazy"
              />

              <div class="flex-1">
                <h3 class="text-left text-[24px] font-[600] leading-tight text-[#1f1f1f]">
                  {image.title}
                </h3>
                <p class="mt-3 text-[16px] leading-[1.6] text-[#4b4b4b]">
                  {image.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <footer class="bg-[#f5f3ee]">
      <div class="border-y border-gray-300 px-6 py-14 lg:px-12 lg:py-12">
        <div class="mx-[75px] flex items-center justify-between gap-6 max-[1024px]:flex-col max-[1024px]:justify-center max-[1024px]:gap-10">
          <a href="/" aria-label="ISO V8 home">
            <img
              src="/assets/images/isov8-logo-colour.svg"
              alt="ISO V8"
              class="h-auto w-[300px] max-w-full"
            />
          </a>

          <p class="text-right text-[30px] font-[400] italic leading-none text-black max-[1024px]:text-center">
            without doubt&reg;
          </p>
        </div>
      </div>

      <div class="border-b border-gray-300 px-6 py-8 lg:px-12">
        <div class="mx-[75px] flex items-center justify-between gap-6 max-[1024px]:flex-col max-[1024px]:items-center max-[1024px]:gap-10">
          <p class="text-[16px] leading-none text-[#6f6f6f] max-[1024px]:text-center">
            &copy; 2025 ContainerKing&reg;. All rights reserved.
          </p>

          <nav aria-label="Footer policies" class="flex items-center gap-8 max-[1024px]:flex-row max-[1024px]:justify-center max-[1024px]:gap-8">
            <a href="/cookie-policy" class="text-[16px] leading-none text-[#6f6f6f] underline transition-colors hover:text-[#088cbc]">
              Cookie Policy
            </a>
            <a href="/privacy-policy" class="text-[16px] leading-none text-[#6f6f6f] underline transition-colors hover:text-[#088cbc]">
              Privacy Policy
            </a>
          </nav>
        </div>
      </div>
    </footer>
  </main>

  <style is:inline>
    .engage-button {
      position: fixed;
      isolation: isolate;
    }

    .engage-button__ring {
      filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.28));
    }

    .engage-button__ring-base,
    .engage-button__ring-progress {
      fill: none;
      stroke-width: 5;
    }

    .engage-button__ring-base {
      stroke: #ffffff;
    }

    .engage-button__ring-progress {
      stroke: #088cbc;
      stroke-dasharray: 100 100;
      stroke-dashoffset: 100.1;
      stroke-linecap: butt;
      opacity: 0;
      transition:
        stroke-dashoffset 900ms ease-in-out,
        opacity 0ms linear 900ms;
    }

    .engage-button:is(:hover, :focus-visible, .is-active) .engage-button__ring-progress,
    .engage-button.is-active .engage-button__ring-progress {
      opacity: 1;
      stroke-dashoffset: 0;
      transition:
        opacity 0ms linear 0ms,
        stroke-dashoffset 900ms ease-in-out;
    }

    .menu-base-platforms-trigger.is-pressed {
      color: #088cbc;
      text-decoration: underline;
    }

    .menu-base-platforms-trigger[aria-expanded="true"] {
      color: #088cbc;
      text-decoration: underline;
    }

    .menu-secondary-link.is-pressed {
      color: #088cbc;
      text-decoration: underline;
    }
  </style>

  <script is:inline>
    const engageButton = document.getElementById("engage-button");
    const contactOverlay = document.getElementById("contact-overlay");
    const contactModal = document.getElementById("contact-modal");
    const contactClose = document.getElementById("contact-close");
    const contactForm = document.getElementById("contact-form");
    const menuToggle = document.getElementById("menu-toggle");
    const menuOverlay = document.getElementById("menu-overlay");
    const menuShell = document.getElementById("menu-shell");
    const menuPanel = document.getElementById("menu-panel");
    const menuClose = document.getElementById("menu-close");
    const menuBasePlatformsTrigger = document.getElementById("menu-base-platforms-trigger");
    const menuBasePlatformsBack = document.getElementById("menu-base-platforms-back");
    const menuBasePlatformsPanel = document.getElementById("menu-base-platforms-panel");
    const menuStructuralHubLink = document.getElementById("menu-structural-hub-link");

    let lockedScrollY = 0;
    let pageLockCount = 0;

    const getTransitionDuration = (element) => {
      const durationSeconds = Number.parseFloat(
        window.getComputedStyle(element).transitionDuration
      );

      return Number.isNaN(durationSeconds) ? 0 : durationSeconds * 1000;
    };

    const lockPageScroll = () => {
      if (pageLockCount === 0) {
        lockedScrollY = window.scrollY;
        document.documentElement.style.overflow = "hidden";
        document.body.style.position = "fixed";
        document.body.style.top = `-${lockedScrollY}px`;
        document.body.style.left = "0";
        document.body.style.right = "0";
        document.body.style.width = "100%";
        document.body.style.overflow = "hidden";
      }

      pageLockCount += 1;
    };

    const unlockPageScroll = () => {
      if (pageLockCount === 0) {
        return;
      }

      pageLockCount -= 1;

      if (pageLockCount > 0) {
        return;
      }

        document.documentElement.style.removeProperty("overflow");
        document.body.style.removeProperty("position");
        document.body.style.removeProperty("top");
        document.body.style.removeProperty("left");
        document.body.style.removeProperty("right");
        document.body.style.removeProperty("width");
        document.body.style.removeProperty("overflow");
        window.scrollTo(0, lockedScrollY);
    };

    if (engageButton && contactOverlay && contactModal && contactClose) {
      let isContactAnimating = false;
      let contactAnimationTimer;

      const setContactState = (isOpen) => {
        engageButton.setAttribute("aria-expanded", String(isOpen));
        contactClose.setAttribute("aria-expanded", String(isOpen));
        engageButton.classList.toggle("is-active", isOpen);
        contactOverlay.setAttribute("aria-hidden", String(!isOpen));
        contactModal.setAttribute("aria-hidden", String(!isOpen));
        contactOverlay.classList.toggle("opacity-0", !isOpen);
        contactOverlay.classList.toggle("opacity-100", isOpen);
        contactModal.classList.toggle("opacity-0", !isOpen);
        contactModal.classList.toggle("opacity-100", isOpen);
        contactOverlay.classList.toggle("pointer-events-none", !isOpen);
        contactOverlay.classList.toggle("pointer-events-auto", isOpen);
        contactModal.classList.toggle("pointer-events-none", !isOpen);
        contactModal.classList.toggle("pointer-events-auto", isOpen);
      };

      const finishContactTransition = () => {
        isContactAnimating = false;
        engageButton.disabled = false;
        contactClose.disabled = false;
        const isOpen = engageButton.getAttribute("aria-expanded") === "true";
        if (!isOpen) {
          unlockPageScroll();
        }
        window.clearTimeout(contactAnimationTimer);
      };

      const requestContactState = (nextIsOpen) => {
        const currentIsOpen = engageButton.getAttribute("aria-expanded") === "true";
        if (isContactAnimating || currentIsOpen === nextIsOpen) {
          return;
        }

        isContactAnimating = true;
        engageButton.disabled = true;
        contactClose.disabled = true;
        if (nextIsOpen) {
          lockPageScroll();
        }
        setContactState(nextIsOpen);

        contactAnimationTimer = window.setTimeout(
          finishContactTransition,
          getTransitionDuration(contactModal) + 50
        );
      };

      engageButton.addEventListener("click", () => {
        requestContactState(true);
      });

      contactClose.addEventListener("click", () => {
        requestContactState(false);
      });

      contactOverlay.addEventListener("click", () => {
        requestContactState(false);
      });

      contactModal.addEventListener("transitionend", (event) => {
        if (event.target === contactModal && event.propertyName === "opacity") {
          finishContactTransition();
        }
      });

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          requestContactState(false);
        }
      });
    }

    if (contactForm) {
      const contactInputs = Array.from(
        contactForm.querySelectorAll("[data-contact-input]")
      );

      const validationMessages = {
        name: {
          valueMissing: "Please enter your name."
        },
        telephone: {
          valueMissing: "Please enter your telephone number.",
          patternMismatch: "Telephone number must contain 7 to 15 digits only."
        },
        "business-name": {
          valueMissing: "Please enter your business name."
        },
        "enquiry-details": {
          valueMissing: "Please enter your enquiry details."
        }
      };

      const getErrorMessage = (input) => {
        const fieldMessages = validationMessages[input.name] ?? {};

        if (input.validity.valueMissing) {
          return fieldMessages.valueMissing ?? "This field is required.";
        }

        if (input.validity.tooShort) {
          return fieldMessages.tooShort ?? "Please enter a little more information.";
        }

        if (input.validity.patternMismatch) {
          return fieldMessages.patternMismatch ?? "Please enter a valid value.";
        }

        return "";
      };

      const setFieldErrorState = (input) => {
        const errorElement = contactForm.querySelector(
          `[data-error-for="${input.name}"]`
        );
        const errorMessage = getErrorMessage(input);
        const hasError = errorMessage.length > 0;

        input.setAttribute("aria-invalid", String(hasError));
        input.classList.toggle("border-[#c53d32]", hasError);
        input.classList.toggle("focus:border-[#c53d32]", hasError);
        input.classList.toggle("border-gray-300", !hasError);
        input.classList.toggle("focus:border-[#088cbc]", !hasError);

        if (errorElement) {
          errorElement.textContent = errorMessage;
        }

        return !hasError;
      };

      contactInputs.forEach((input) => {
        input.addEventListener("blur", () => {
          setFieldErrorState(input);
        });

        input.addEventListener("input", () => {
          if (input.name === "telephone") {
            input.value = input.value.replace(/\D+/g, "");
          }

          if (input.getAttribute("aria-invalid") === "true") {
            setFieldErrorState(input);
          }
        });
      });

      contactForm.addEventListener("submit", (event) => {
        event.preventDefault();

        const firstInvalidInput = contactInputs.find((input) => !setFieldErrorState(input));

        if (firstInvalidInput) {
          firstInvalidInput.focus();
          return;
        }
      });
    }

    if (menuToggle && menuOverlay && menuShell && menuPanel && menuClose) {
      let isMenuAnimating = false;
      let isBasePlatformsAnimating = false;
      let animationTimer;
      let basePlatformsAnimationTimer;

      const isMenuOpen = () => menuToggle.getAttribute("aria-expanded") === "true";
      const isBasePlatformsPanelOpen = () =>
        menuBasePlatformsTrigger?.getAttribute("aria-expanded") === "true";

      const syncMenuInteractivity = () => {
        const menuIsOpen = isMenuOpen();
        menuShell.style.pointerEvents = menuIsOpen ? "auto" : "none";
      };

      const setMenuShellTransform = (isOpen) => {
        if (!isOpen) {
          menuShell.style.transform = "translateX(-100%)";
          return;
        }

        menuShell.style.transform = "translateX(0)";
      };

      const resetBasePlatformsPanelState = () => {
        if (!menuBasePlatformsTrigger || !menuBasePlatformsPanel) {
          return;
        }

        menuBasePlatformsTrigger.setAttribute("aria-expanded", "false");
        menuBasePlatformsPanel.setAttribute("aria-hidden", "true");
        menuBasePlatformsPanel.classList.add("hidden");
        menuBasePlatformsPanel.classList.add("pointer-events-none");
        menuBasePlatformsPanel.classList.remove("pointer-events-auto");
        menuBasePlatformsPanel.style.transform = "translateX(-100%)";
      };

      const finishBasePlatformsTransition = () => {
        if (!isBasePlatformsAnimating) {
          return;
        }

        isBasePlatformsAnimating = false;

        if (menuBasePlatformsPanel?.getAttribute("aria-hidden") === "true") {
          menuBasePlatformsPanel.classList.add("hidden");
        }

        window.clearTimeout(basePlatformsAnimationTimer);
        syncMenuInteractivity();
      };

      const setBasePlatformsPanelState = (isOpen) => {
        if (!menuBasePlatformsTrigger || !menuBasePlatformsPanel) {
          return;
        }

        const currentIsOpen = isBasePlatformsPanelOpen();
        if (isMenuAnimating || isBasePlatformsAnimating || currentIsOpen === isOpen) {
          return;
        }

        isBasePlatformsAnimating = true;
        menuBasePlatformsTrigger.setAttribute("aria-expanded", String(isOpen));
        menuBasePlatformsPanel.setAttribute("aria-hidden", String(!isOpen));
        syncMenuInteractivity();
        window.clearTimeout(basePlatformsAnimationTimer);

        basePlatformsAnimationTimer = window.setTimeout(
          finishBasePlatformsTransition,
          getTransitionDuration(menuBasePlatformsPanel) + 50
        );

        if (isOpen) {
          menuBasePlatformsPanel.style.transform = "translateX(-100%)";
          menuBasePlatformsPanel.classList.remove("hidden");

          window.requestAnimationFrame(() => {
            menuBasePlatformsPanel.classList.remove("pointer-events-none");
            menuBasePlatformsPanel.classList.add("pointer-events-auto");
            menuBasePlatformsPanel.style.transform = "translateX(0)";
            if (menuToggle.getAttribute("aria-expanded") === "true") {
              setMenuShellTransform(true);
            }
          });

          return;
        }

        menuBasePlatformsPanel.classList.add("pointer-events-none");
        menuBasePlatformsPanel.classList.remove("pointer-events-auto");
        menuBasePlatformsPanel.style.transform = "translateX(-100%)";

        if (menuToggle.getAttribute("aria-expanded") === "true") {
          setMenuShellTransform(true);
        }
      };

      const setMenuState = (isOpen) => {
        menuToggle.setAttribute("aria-expanded", String(isOpen));
        menuClose.setAttribute("aria-expanded", String(isOpen));
        menuOverlay.setAttribute("aria-hidden", String(!isOpen));
        menuPanel.setAttribute("aria-hidden", String(!isOpen));
        menuOverlay.classList.toggle("opacity-0", !isOpen);
        menuOverlay.classList.toggle("opacity-100", isOpen);
        setMenuShellTransform(isOpen);

        if (!isOpen) {
          menuBasePlatformsTrigger?.setAttribute("aria-expanded", "false");
          menuBasePlatformsPanel?.classList.add("pointer-events-none");
          menuBasePlatformsPanel?.classList.remove("pointer-events-auto");
        }

        syncMenuInteractivity();
      };

      const finishMenuTransition = () => {
        if (!isMenuAnimating) {
          return;
        }

        isMenuAnimating = false;
        const isOpen = isMenuOpen();
        menuOverlay.classList.toggle("pointer-events-none", !isOpen);
        menuOverlay.classList.toggle("pointer-events-auto", isOpen);
        if (!isOpen) {
          resetBasePlatformsPanelState();
          unlockPageScroll();
        }
        window.clearTimeout(animationTimer);
        syncMenuInteractivity();
      };

      const requestMenuState = (nextIsOpen) => {
        const currentIsOpen = isMenuOpen();
        if (isMenuAnimating || isBasePlatformsAnimating || currentIsOpen === nextIsOpen) {
          return;
        }

        isMenuAnimating = true;
        menuOverlay.classList.remove("pointer-events-none");
        menuOverlay.classList.add("pointer-events-auto");
        if (nextIsOpen) {
          lockPageScroll();
        }
        setMenuState(nextIsOpen);

        animationTimer = window.setTimeout(
          finishMenuTransition,
          getTransitionDuration(menuShell) + 50
        );
      };

      menuToggle.addEventListener("click", () => {
        requestMenuState(true);
      });

      menuClose.addEventListener("click", () => {
        requestMenuState(false);
      });

      menuOverlay.addEventListener("click", () => {
        requestMenuState(false);
      });

      if (menuBasePlatformsTrigger && menuBasePlatformsPanel) {
        const activateBasePlatformsTriggerPressState = () => {
          menuBasePlatformsTrigger.classList.add("is-pressed");
        };

        const clearBasePlatformsTriggerPressState = () => {
          menuBasePlatformsTrigger.classList.remove("is-pressed");
        };

        menuBasePlatformsTrigger.addEventListener("pointerdown", () => {
          activateBasePlatformsTriggerPressState();
        });

        menuBasePlatformsTrigger.addEventListener("pointerup", () => {
          clearBasePlatformsTriggerPressState();
        });

        menuBasePlatformsTrigger.addEventListener("pointercancel", () => {
          clearBasePlatformsTriggerPressState();
        });

        menuBasePlatformsTrigger.addEventListener("pointerleave", () => {
          clearBasePlatformsTriggerPressState();
        });

        menuBasePlatformsTrigger.addEventListener("blur", () => {
          clearBasePlatformsTriggerPressState();
        });

        menuBasePlatformsTrigger.addEventListener("click", () => {
          clearBasePlatformsTriggerPressState();
          const isOpen =
            menuBasePlatformsTrigger.getAttribute("aria-expanded") === "true";

          setBasePlatformsPanelState(!isOpen);
        });
      }

      if (menuBasePlatformsBack) {
        menuBasePlatformsBack.addEventListener("click", () => {
          setBasePlatformsPanelState(false);
        });
      }

      if (menuStructuralHubLink) {
        const activateStructuralHubLinkPressState = () => {
          menuStructuralHubLink.classList.add("is-pressed");
        };

        const clearStructuralHubLinkPressState = () => {
          menuStructuralHubLink.classList.remove("is-pressed");
        };

        menuStructuralHubLink.addEventListener("pointerdown", () => {
          activateStructuralHubLinkPressState();
        });

        menuStructuralHubLink.addEventListener("pointerup", () => {
          clearStructuralHubLinkPressState();
        });

        menuStructuralHubLink.addEventListener("pointercancel", () => {
          clearStructuralHubLinkPressState();
        });

        menuStructuralHubLink.addEventListener("pointerleave", () => {
          clearStructuralHubLinkPressState();
        });

        menuStructuralHubLink.addEventListener("blur", () => {
          clearStructuralHubLinkPressState();
        });

        menuStructuralHubLink.addEventListener("click", () => {
          clearStructuralHubLinkPressState();
        });
      }

      menuShell.addEventListener("transitionend", (event) => {
        if (event.propertyName === "transform" && isMenuAnimating) {
          finishMenuTransition();
        }
      });

      if (menuBasePlatformsPanel) {
        menuBasePlatformsPanel.addEventListener("transitionend", (event) => {
          if (event.propertyName === "transform" && isBasePlatformsAnimating) {
            finishBasePlatformsTransition();
          }
        });
      }

      window.addEventListener("resize", () => {
        const isOpen = isMenuOpen();
        setMenuShellTransform(isOpen);
      });

    }
  </script>
</BaseLayout>
