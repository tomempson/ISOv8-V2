---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Contact | ISOv8"
  description="Get in touch with ISOv8 about your container conversion project."
>
  <div class="flex min-h-screen flex-col bg-white text-[#111111]">
    <main class="flex flex-1 flex-col items-center justify-center px-6 py-16">
      <div class="w-full max-w-[760px]">
        <div class="mb-7 flex items-center justify-between gap-6">
          <div class="flex items-center gap-3">
            <h3 class="text-[40px] font-[600] leading-none text-black">Just As</h3>
            <img
              src="/assets/images/container-king-logo-mark-colour.svg"
              alt="Container King"
              class="-ml-1 h-9 w-auto"
            />
          </div>

          <a
            href="tel:01724870000"
            class="text-[28px] font-[600] leading-none text-[#088cbc] transition-opacity hover:opacity-80"
          >
            01724 870000
          </a>
        </div>

        <form
          id="contact-form"
          name="engage-contact"
          method="POST"
          action="/thank-you/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          novalidate
        >
          <input type="hidden" name="form-name" value="engage-contact" />
          <p class="hidden" aria-hidden="true">
            <label>
              Don&apos;t fill this out if you&apos;re human:
              <input type="text" name="bot-field" tabindex="-1" autocomplete="off" />
            </label>
          </p>

          <div class="grid gap-2 md:grid-cols-2 lg:gap-3">
            <div class="flex flex-col gap-1">
              <input
                type="text"
                name="name"
                aria-label="Name"
                placeholder="Name"
                autocomplete="name"
                required
                maxlength="80"
                data-contact-input
                class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[16px] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus:border-[#088cbc]"
              />
              <p
                data-error-for="name"
                class="min-h-[16px] text-[12px] leading-tight text-[#c53d32]"
              ></p>
            </div>

            <div class="flex flex-col gap-1">
              <input
                type="text"
                name="telephone"
                aria-label="Telephone Number"
                placeholder="Telephone Number"
                autocomplete="tel"
                inputmode="numeric"
                required
                pattern="^[0-9]{7,15}$"
                data-contact-input
                class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[16px] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus:border-[#088cbc]"
              />
              <p
                data-error-for="telephone"
                class="min-h-[16px] text-[12px] leading-tight text-[#c53d32]"
              ></p>
            </div>

            <div class="flex flex-col gap-1 md:col-span-2">
              <input
                type="text"
                name="business-name"
                aria-label="Business Name"
                placeholder="Business Name"
                autocomplete="organization"
                required
                maxlength="100"
                data-contact-input
                class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[16px] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus:border-[#088cbc]"
              />
              <p
                data-error-for="business-name"
                class="min-h-[16px] text-[12px] leading-tight text-[#c53d32]"
              ></p>
            </div>

            <div class="flex flex-col gap-1 md:col-span-2">
              <textarea
                name="enquiry-details"
                rows="5"
                aria-label="Enquiry Details"
                placeholder="Enquiry Details"
                required
                maxlength="1000"
                data-contact-input
                class="w-full resize-none rounded-[6px] border border-gray-300 bg-white px-4 py-3 text-[16px] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus:border-[#088cbc]"
              ></textarea>
              <p
                data-error-for="enquiry-details"
                class="min-h-[16px] text-[12px] leading-tight text-[#c53d32]"
              ></p>
            </div>
          </div>

          <div class="mt-3 grid grid-cols-2 gap-3">
            <button
              type="submit"
              class="h-12 w-full cursor-pointer rounded-[6px] bg-[#088cbc] px-8 text-[16px] font-[600] leading-none text-white transition-opacity hover:opacity-90"
            >
              Submit
            </button>
            <a
              href="/"
              class="flex h-12 w-full items-center justify-center rounded-[6px] border border-gray-300 text-[16px] font-[600] leading-none text-[#1f1f1f] transition-opacity hover:opacity-70"
            >
              Return Home
            </a>
          </div>
        </form>
      </div>
    </main>

    <SiteFooter />
  </div>

  <script is:inline>
    (() => {
      const contactForm = document.getElementById("contact-form");
      if (!contactForm) return;

      const contactInputs = Array.from(
        contactForm.querySelectorAll("[data-contact-input]")
      );

      const validationMessages = {
        name: {
          valueMissing: "Please enter your name."
        },
        telephone: {
          valueMissing: "Please enter your telephone number.",
          patternMismatch: "Telephone number must contain 7 to 15 digits only."
        },
        "business-name": {
          valueMissing: "Please enter your business name."
        },
        "enquiry-details": {
          valueMissing: "Please enter your enquiry details."
        }
      };

      const getErrorMessage = (input) => {
        const fieldMessages = validationMessages[input.name] ?? {};
        if (input.validity.valueMissing) return fieldMessages.valueMissing ?? "This field is required.";
        if (input.validity.tooShort) return fieldMessages.tooShort ?? "Please enter a little more information.";
        if (input.validity.patternMismatch) return fieldMessages.patternMismatch ?? "Please enter a valid value.";
        return "";
      };

      const setFieldErrorState = (input) => {
        const errorElement = contactForm.querySelector(`[data-error-for="${input.name}"]`);
        const errorMessage = getErrorMessage(input);
        const hasError = errorMessage.length > 0;
        input.setAttribute("aria-invalid", String(hasError));
        input.classList.toggle("border-[#c53d32]", hasError);
        input.classList.toggle("focus:border-[#c53d32]", hasError);
        input.classList.toggle("border-gray-300", !hasError);
        input.classList.toggle("focus:border-[#088cbc]", !hasError);
        if (errorElement) errorElement.textContent = errorMessage;
        return !hasError;
      };

      contactInputs.forEach((input) => {
        input.addEventListener("blur", () => setFieldErrorState(input));
        input.addEventListener("input", () => {
          if (input.name === "telephone") input.value = input.value.replace(/\D+/g, "");
          if (input.getAttribute("aria-invalid") === "true") setFieldErrorState(input);
        });
      });

      contactForm.addEventListener("submit", (event) => {
        event.preventDefault();
        const firstInvalidInput = contactInputs.find((input) => !setFieldErrorState(input));
        if (firstInvalidInput) { firstInvalidInput.focus(); return; }

        try {
          const summaryData = {};
          contactInputs.forEach((input) => { summaryData[input.name] = input.value; });
          sessionStorage.setItem("engage-contact-data", JSON.stringify(summaryData));
        } catch (_) {}

        const formData = new FormData(contactForm);
        fetch("/", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams(formData).toString()
        })
          .then(() => { window.location.href = "/thank-you/"; })
          .catch(() => { window.location.href = "/thank-you/"; });
      });
    })();
  </script>
</BaseLayout>
