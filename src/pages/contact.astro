---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ContactForm from "../components/ContactForm.astro";
---

<BaseLayout
  title="ISOv8® | Contact"
  description="Get in touch with ISOv8 about your container conversion project."
>
  <div class="flex min-h-screen flex-col bg-white text-[#111111]">
    <main id="main-content" tabindex="-1" class="flex flex-1 flex-col items-center justify-center px-6 py-16">
      <div class="w-full max-w-[760px]">
        <ContactForm variant="page" />
      </div>
    </main>

    <SiteFooter />
  </div>
</BaseLayout>
