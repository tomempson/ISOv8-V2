---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="ISOv8® | Page Not Found"
  description="The page you're looking for doesn't exist or has been moved."
  noindex
>
  <div class="flex min-h-screen flex-col bg-white text-[#111111]">
    <main id="main-content" tabindex="-1" class="flex flex-1 flex-col items-center justify-center px-6 py-16">
      <h1
        class="text-center text-[3.75rem] font-[700] uppercase leading-[1] tracking-tight text-[#1f1f1f] md:text-[5.625rem] lg:text-[7.5rem]"
      >
        404
      </h1>

      <p class="mt-5 max-w-lg text-center text-[1.125rem] font-[400] leading-[1.8] text-[#6f6f6f]">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <a
        href="/"
        class="mt-10 inline-block rounded-md px-14 py-5 text-[1.25rem] font-[500] uppercase tracking-[0.05em] text-white transition-opacity duration-300 hover:opacity-85"
        style="background: var(--color-brand);"
      >
        Return Home
      </a>
    </main>

    <SiteFooter />
  </div>
</BaseLayout>
