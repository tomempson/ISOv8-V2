---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import EngageContact from "../components/EngageContact.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import logoPng from "../assets/images/isov8-logo.png";
---

<BaseLayout
  title="ISOv8® | About Us"
  description="About ISOv8® — a UK business delivering shipping container conversions and steel anti-vandal buildings with a focus on clarity, specification, and long-term performance."
  keywords={["about ISOv8", "container conversion company UK", "steel anti-vandal buildings UK", "container conversions Lincolnshire", "portable buildings Scunthorpe"]}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://isov8-v2.netlify.app/" },
      { "@type": "ListItem", "position": 2, "name": "About Us" }
    ]
  })} />
  <div class="min-h-screen bg-white text-[#111111]">
    <main id="main-content" class="min-h-screen bg-white">
      <EngageContact />
      <SiteHeader backHref="/" />
      <div class="bg-white px-8 py-10 lg:px-12 lg:py-12">
        <section class="relative my-6 overflow-hidden py-8 md:my-8 md:py-10 xl:my-0 xl:py-0">
          <Image
            src={logoPng}
            alt="About Us"
            class="block w-full"
            decoding="async"
          />

          <div class="absolute inset-0 pl-[48px] pr-8 text-left text-black">
            <div class="absolute left-[48px] top-1/2 max-w-5xl -translate-y-1/2">
              <h1 class="max-w-4xl text-[2.625rem] font-[600] leading-[1.08]">
                About Us
              </h1>
            </div>
          </div>
        </section>

        <div id="toc-region" class="mt-12 xl:relative xl:grid xl:grid-cols-[minmax(0,1fr)_280px] xl:gap-12">
          <div
            class="pointer-events-none absolute bottom-0 right-[304px] top-0 hidden w-px bg-gray-200 xl:block"
            aria-hidden="true"
          ></div>

          <div>
            <p class="text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; operates as a sub brand and part of ContainerKing&reg; Limited, a UK registered business established through over 30 years of hands-on work in shipping containers, anti-vandal and portable buildings, and specialist fabrication.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; is not a new venture or a rebranded offer.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; exists to focus specifically on shipping container conversions and steel anti-vandal buildings supply to customers where specification, build quality, and long-term performance matter.
            </p>

            <h2 id="where-we-come-from" class="mt-12 text-[1.75rem] font-[600] leading-[1.2] text-black">Where We Come From</h2>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              ContainerKing&reg; has been built from the ground up — supplying, modifying, and delivering container and anti-vandal building solutions across a wide range of industries.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              That experience is practical, not theoretical.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              It comes from:
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-8 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              <li>designing and building units that are used daily</li>
              <li>resolving real-world problems</li>
              <li>and understanding how these structures perform over time</li>
            </ul>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; applies that experience to projects where detail, specification, and correct decision-making at the outset are critical.
            </p>

            <h2 id="leadership-and-direction" class="mt-12 text-[1.75rem] font-[600] leading-[1.2] text-black">Leadership &amp; Direction</h2>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; is led by Steve Empson, Managing Director of ContainerKing&reg; Limited.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              The business has been shaped through long-term commercial experience, including both successful growth and periods of significant challenge. Years of learning and our background has formed my views on how a proper business should operate and also how the correct decisions should be made — with a focus on structure, clarity, and long-term outcome rather than short-term gain.
            </p>

            <h2 id="what-kind-of-business-we-are" class="mt-12 text-[1.75rem] font-[600] leading-[1.2] text-black">What Kind of Business We Are</h2>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              We are a build-led business.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              We are not sales-driven, and we are not structured around volume.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              Our focus is on:
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-8 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              <li>defining requirements properly</li>
              <li>specifying correctly</li>
              <li>and delivering work that performs as intended</li>
            </ul>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              Our approach (we appreciate) may not suit every customer or project.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              It is designed for clients who value:
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-8 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              <li>clarity before commitment</li>
              <li>realistic specification</li>
              <li>and outcomes that stand up over time</li>
            </ul>

            <h2 id="how-we-approach-work" class="mt-12 text-[1.75rem] font-[600] leading-[1.2] text-black">How We Approach Work</h2>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              Most problems in this sector originate before fabrication begins.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              We focus on:
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-8 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              <li>understanding the requirement in detail</li>
              <li>identifying constraints early</li>
              <li>and ensuring the proposed solution is appropriate</li>
            </ul>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              That often means:
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-8 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              <li>asking direct questions</li>
              <li>challenging assumptions</li>
              <li>and occasionally advising against a proposed route</li>
            </ul>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              The objective is simple — get it right before it is built.
            </p>

            <h2 id="backed-by-containerking" class="mt-12 text-[1.75rem] font-[600] leading-[1.2] text-black">Backed by ContainerKing&reg;</h2>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; operates within ContainerKing&reg; Limited, with full access to:
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-8 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              <li>fabrication facilities</li>
              <li>experienced trades and engineers</li>
              <li>container supply and modification capability</li>
              <li>delivery and installation infrastructure</li>
            </ul>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              This provides full control from concept through to completion.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              One team. One build. One point of responsibility.
            </p>

            <h2 id="who-we-work-with" class="mt-12 text-[1.75rem] font-[600] leading-[1.2] text-black">Who We Work With</h2>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              We work with commercially aware customers who need reliable, correctly specified space, including:
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-8 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              <li>business owners and operators</li>
              <li>engineers and manufacturers</li>
              <li>contractors and infrastructure providers</li>
              <li>local authorities and commercial organisations</li>
            </ul>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              We are best suited to projects where:
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-8 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              <li>decisions are considered</li>
              <li>quality is prioritised</li>
              <li>and long-term value matters</li>
            </ul>

            <h2 id="where-we-operate" class="mt-12 text-[1.75rem] font-[600] leading-[1.2] text-black">Where We Operate</h2>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; operates from Scunthorpe, North Lincolnshire, delivering shipping container conversions and steel anti-vandal buildings across Lincolnshire, Yorkshire &amp; Humberside, the Midlands, and throughout the UK.
            </p>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              From our North Lincolnshire base, we supply and deliver bespoke container conversions and steel anti-vandal buildings to businesses, contractors, and organisations across:
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-8 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              <li>Lincolnshire — including Scunthorpe, Lincoln, and surrounding areas</li>
              <li>Yorkshire &amp; Humberside — including Hull, Doncaster, Sheffield, and Leeds</li>
              <li>The Midlands — including Nottingham, Derby, Leicester, and wider regions</li>
              <li>Nationwide UK coverage for commercial and specialist projects</li>
            </ul>
            <p class="mt-6 text-[1.0625rem] leading-[1.8] text-[#4b5563]">
              All units are built in-house and delivered using experienced HIAB hauliers, with clear guidance provided on site access, positioning, and installation to ensure a controlled and reliable delivery process.
            </p>
          </div>

          <aside id="toc-rail" class="mt-12 hidden xl:relative xl:mt-0 xl:block xl:self-stretch xl:justify-self-end xl:w-full xl:max-w-[280px] xl:pl-6">
            <div id="toc-panel" class="p-0">
              <p class="text-[1.25rem] font-[600] leading-tight text-black">
                Table of Contents
              </p>

              <nav aria-label="Table of contents" class="mt-5">
                <ul class="space-y-3 text-left">
                  <li>
                    <a href="#where-we-come-from" data-toc-link="where-we-come-from" class="text-[1.0625rem] leading-[1.5] text-[#4b5563] transition-colors hover:text-[#088cbc] hover:underline">
                      Where We Come From
                    </a>
                  </li>
                  <li>
                    <a href="#leadership-and-direction" data-toc-link="leadership-and-direction" class="text-[1.0625rem] leading-[1.5] text-[#4b5563] transition-colors hover:text-[#088cbc] hover:underline">
                      Leadership &amp; Direction
                    </a>
                  </li>
                  <li>
                    <a href="#what-kind-of-business-we-are" data-toc-link="what-kind-of-business-we-are" class="text-[1.0625rem] leading-[1.5] text-[#4b5563] transition-colors hover:text-[#088cbc] hover:underline">
                      What Kind of Business We Are
                    </a>
                  </li>
                  <li>
                    <a href="#how-we-approach-work" data-toc-link="how-we-approach-work" class="text-[1.0625rem] leading-[1.5] text-[#4b5563] transition-colors hover:text-[#088cbc] hover:underline">
                      How We Approach Work
                    </a>
                  </li>
                  <li>
                    <a href="#backed-by-containerking" data-toc-link="backed-by-containerking" class="text-[1.0625rem] leading-[1.5] text-[#4b5563] transition-colors hover:text-[#088cbc] hover:underline">
                      Backed by ContainerKing&reg;
                    </a>
                  </li>
                  <li>
                    <a href="#who-we-work-with" data-toc-link="who-we-work-with" class="text-[1.0625rem] leading-[1.5] text-[#4b5563] transition-colors hover:text-[#088cbc] hover:underline">
                      Who We Work With
                    </a>
                  </li>
                  <li>
                    <a href="#where-we-operate" data-toc-link="where-we-operate" class="text-[1.0625rem] leading-[1.5] text-[#4b5563] transition-colors hover:text-[#088cbc] hover:underline">
                      Where We Operate
                    </a>
                  </li>
                </ul>
              </nav>
            </div>
          </aside>
        </div>

        <section class="mt-12 border-t border-gray-200 pt-8 text-[#111111]">
          <div class="space-y-4">
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              If you are considering commissioning a container office, workshop, storage unit or secure anti-vandal unit for site use and want clarity on structural suitability before specification is fixed, speak with ISOv8&reg;. A short early discussion prevents disproportionate reinforcement and reactive redesign.
            </p>
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; by ContainerKing&reg; Limited Scunthorpe, North Lincolnshire<br />Tel: 01724 870000<br />Nationwide delivery across England, Scotland &amp; Wales
            </p>
          </div>
        </section>

        <section id="page-legal" class="mt-8 border-t border-gray-200 pt-8 text-[#111111]">
          <div class="space-y-3">
            <p class="text-[1.125rem] font-[600] leading-tight">Legal Disclaimer</p>
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              The content provided in this document is for general information purposes only and is not intended to constitute legal, planning, building control, health and safety, or professional advice. Regulations and site-specific requirements vary widely across the UK. ISOv8&reg; by ContainerKing&reg; does not accept liability for actions taken, losses incurred, or decisions made based on the information provided. Always consult your local authority, planning department, building inspector, legal adviser, or relevant professional before starting any container project. Use of this document is entirely at your own risk.
            </p>
          </div>

          <div class="mt-8 space-y-3">
            <p class="text-[1.125rem] font-[600] leading-tight">Copyright Notice</p>
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              &copy; 2025 ISOv8&reg; by ContainerKing&reg;. All rights reserved. You are welcome to link to this page or share brief excerpts for commentary, review, or non-commercial purposes, provided proper credit is given to ISOv8&reg; by ContainerKing&reg;. No part of this document may be reproduced, distributed, or transmitted in full in any form or by any means without prior written permission from ISOv8&reg; by ContainerKing&reg;.
            </p>
          </div>
        </section>
      </div>
      <SiteFooter />
    </main>
  </div>
  <script>
    const tocRail = document.getElementById("toc-rail");
    const tocPanel = document.getElementById("toc-panel");
    const tocRegion = document.getElementById("toc-region");
    const desktopMq = window.matchMedia("(min-width: 1280px)");

    const resetTocPanel = () => {
      if (!tocPanel) {
        return;
      }

      tocPanel.style.removeProperty("position");
      tocPanel.style.removeProperty("top");
      tocPanel.style.removeProperty("left");
      tocPanel.style.removeProperty("right");
      tocPanel.style.removeProperty("width");
    };

    const updateTocPanel = () => {
      if (!tocRail || !tocPanel || !tocRegion || !desktopMq.matches) {
        resetTocPanel();
        return;
      }

      resetTocPanel();

      const railRect = tocRail.getBoundingClientRect();
      const regionRect = tocRegion.getBoundingClientRect();
      const panelRect = tocPanel.getBoundingClientRect();
      const railTop = railRect.top + window.scrollY;
      const regionBottom = regionRect.bottom + window.scrollY;
      const panelNaturalLeft = panelRect.left;
      const panelNaturalWidth = panelRect.width;
      const panelOffsetWithinRail = panelNaturalLeft - railRect.left;
      const currentScroll = window.scrollY;
      const fixedTop = 24;
      const startPoint = railTop - fixedTop;
      const stopPoint = regionBottom - tocPanel.offsetHeight - fixedTop;

      if (currentScroll <= startPoint) {
        resetTocPanel();
        return;
      }

      if (currentScroll >= stopPoint) {
        tocPanel.style.position = "absolute";
        tocPanel.style.top = `${Math.max(regionBottom - railTop - tocPanel.offsetHeight, 0)}px`;
        tocPanel.style.left = `${panelOffsetWithinRail}px`;
        tocPanel.style.right = "auto";
        tocPanel.style.width = `${panelNaturalWidth}px`;
        return;
      }

      tocPanel.style.position = "fixed";
      tocPanel.style.top = `${fixedTop}px`;
      tocPanel.style.left = `${panelNaturalLeft}px`;
      tocPanel.style.right = "auto";
      tocPanel.style.width = `${panelNaturalWidth}px`;
    };

    updateTocPanel();
    window.addEventListener("scroll", updateTocPanel, { passive: true });
    window.addEventListener("resize", updateTocPanel);
    desktopMq.addEventListener("change", updateTocPanel);

    const tocLinks = document.querySelectorAll("[data-toc-link]");
    if (tocLinks.length > 0) {
      const headingIds = Array.from(tocLinks).map(
        (link) => link.getAttribute("data-toc-link")
      );
      const headingEls = headingIds
        .map((id) => document.getElementById(id))
        .filter(Boolean);

      const setActive = (id) => {
        tocLinks.forEach((link) => {
          if (link.getAttribute("data-toc-link") === id) {
            link.classList.remove("text-[#4b5563]");
            link.classList.add("text-[#088cbc]", "underline");
          } else {
            link.classList.add("text-[#4b5563]");
            link.classList.remove("text-[#088cbc]", "underline");
          }
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
            }
          });
        },
        { rootMargin: "0px 0px -70% 0px", threshold: 0 }
      );

      headingEls.forEach((el) => observer.observe(el));
    }
  </script>
</BaseLayout>
