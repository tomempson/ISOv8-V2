---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import EngageContact from "../components/EngageContact.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PortableTextRenderer from "../components/portable-text/PortableTextRenderer.astro";
import { structuralSidebarLinks } from "../data/structuralSidebarLinks";
import { getAllPages } from "../utils/sanity";
import { extractH2s } from "../utils/portable-text";
import phase1Img from "../assets/images/phase-1.jpg";
import logoPng from "../assets/images/isov8-logo.png";

export async function getStaticPaths() {
  const pages = await getAllPages();

  return pages.map((page: any) => {
    const fullSlug = page.phase && page.section
      ? `${page.phase}/${page.section}/${page.slug}`
      : page.slug;

    return {
      params: { slug: fullSlug },
      props: { page, fullSlug },
    };
  });
}

const { page, fullSlug } = Astro.props;

const currentPath = `/${fullSlug}`;
const headings = extractH2s(page.body);

const phaseIdMap: Record<string, string> = {
  understand: "phase-1",
  define: "phase-2",
  see: "phase-3",
  perform: "phase-4",
  align: "phase-5",
};

const sectionIdMap: Record<string, string> = {
  "base-platforms-and-structural-principles": "base-platforms",
  "structural-behavior-and-modification-limits": "structural-behaviour",
  "performance-comfort-and-longevity": "performance-comfort",
  "planning-legal-and-compliance": "planning-legal",
  "commercial-and-financial-hub": "commercial-financial",
  "decision-framework": "decision-frameworks",
  "red-flag-warnings": "red-flag-warnings",
  "reality-chq": "reality-chq",
  "platform-section": "platform-selection",
  "real-world-product-examples": "real-world-examples",
  "industries-and-operational-use": "industries-operational",
  "from-a-to-done": "from-a-to-done",
  "internal-finishes-and-fit-out-options": "internal-finishes",
  "maintenance-condition-control-and-aftercare": "maintenance-aftercare",
  "practical-execution-and-ownership": "practical-execution",
  "technical-reference-hub": "technical-reference",
  "project-definition-and-alignment": "project-definition",
  "transport-and-geography": "transport-geography",
};

const phaseLabelMap: Record<string, string> = {
  understand: "Phase 1 - Understand",
  define: "Phase 2 - Define",
  see: "Phase 3 - See",
  perform: "Phase 4 - Perform",
  align: "Phase 5 - Align",
};

const sectionLabelMap: Record<string, string> = {
  "base-platforms-and-structural-principles": "Base Platforms & Structural Principles",
  "structural-behavior-and-modification-limits": "Structural Behaviour & Modification Limits",
  "performance-comfort-and-longevity": "Performance, Comfort & Longevity",
  "planning-legal-and-compliance": "Planning, Legal and Compliance",
  "commercial-and-financial-hub": "Commercial & Financial Hub",
  "decision-framework": "Decision Frameworks",
  "red-flag-warnings": "Red Flag Warnings",
  "reality-chq": "Reality CHQ\u2122",
  "platform-section": "Platform Selection",
  "real-world-product-examples": "Real-World Product Examples",
  "industries-and-operational-use": "Industries & Operational Use",
  "from-a-to-done": "From A to Done\u2122",
  "internal-finishes-and-fit-out-options": "Internal Finishes & Fit-Out Options",
  "maintenance-condition-control-and-aftercare": "Maintenance, Condition Control & Aftercare",
  "practical-execution-and-ownership": "Practical Execution & Ownership",
  "technical-reference-hub": "Technical Reference Hub",
  "project-definition-and-alignment": "Project Definition & Alignment",
  "transport-and-geography": "Transport and Geography",
};

const breadcrumbItems = [
  { "@type": "ListItem" as const, "position": 1, "name": "Home", "item": "https://isov8-v2.netlify.app/" },
];
if (page.phase && phaseLabelMap[page.phase]) {
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": 2,
    "name": phaseLabelMap[page.phase],
    "item": `https://isov8-v2.netlify.app/?phase=${phaseIdMap[page.phase]}`,
  });
}
if (page.section && sectionLabelMap[page.section]) {
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": 3,
    "name": sectionLabelMap[page.section],
    "item": `https://isov8-v2.netlify.app/?phase=${phaseIdMap[page.phase]}&section=${sectionIdMap[page.section]}`,
  });
}
breadcrumbItems.push({
  "@type": "ListItem",
  "position": breadcrumbItems.length + 1,
  "name": page.metaTitle || page.h1Title || "Page",
} as any);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems,
    },
    {
      "@type": "Article",
      "headline": page.h1Title || page.metaTitle,
      "description": page.metaDescription,
      "author": { "@type": "Organization", "name": "ISOv8® by ContainerKing® Limited" },
      "publisher": { "@id": "https://isov8-v2.netlify.app/#organization" },
      "dateModified": page._updatedAt,
      "mainEntityOfPage": `https://isov8-v2.netlify.app/${fullSlug}`,
    },
  ],
};

const backPhase = page.phase ? phaseIdMap[page.phase] : null;
const backSection = page.section ? sectionIdMap[page.section] : null;
const backParams = new URLSearchParams();
if (backPhase) backParams.set("phase", backPhase);
if (backSection) backParams.set("section", backSection);
const backHref = backParams.toString() ? `/?${backParams.toString()}` : "/";
---

<BaseLayout
  title={page.metaTitle ? `ISOv8\u00AE | ${page.metaTitle}` : "ISOv8\u00AE"}
  description={page.metaDescription}
  keywords={page.metaKeywords}
  ogType="article"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <div class="min-h-screen bg-white text-[#111111] lg:pl-[350px]">
    <aside
      class="hidden border-b border-gray-300 bg-white lg:fixed lg:inset-y-0 lg:left-0 lg:z-20 lg:block lg:w-[350px] lg:overflow-y-auto lg:border-b-0 lg:border-r"
    >
      <Image
        src={phase1Img}
        alt=""
        aria-hidden="true"
        class="block w-full"
        width={350}
        height={250}
        decoding="async"
      />

      <div class="flex items-center gap-4 px-[30px] py-8 lg:mt-[18px] lg:px-[45px]">
        <a
          href={backHref}
          aria-label="Back to home"
          class="flex h-5 w-5 shrink-0 items-center justify-center text-black transition-colors hover:text-[#088cbc]"
        >
          <svg
            class="h-5 w-5"
            viewBox="0 0 20 20"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M13 4L7 10L13 16"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>

        <p class="text-[1.25rem] font-[500] leading-tight text-black">
          Base Platforms & Structural Principles
        </p>
      </div>

      <div class="px-[30px] pb-10 lg:px-[45px]">
        <div class="flex flex-col gap-6">
          {
            structuralSidebarLinks.map((link) => {
              const isActive = link.href === currentPath;
              return (
                <a
                  href={link.href}
                  aria-current={isActive ? "page" : undefined}
                  class:list={[
                    "inline-block text-left text-[1.125rem] font-[400] leading-tight transition-colors",
                    isActive
                      ? "text-[#088cbc] underline decoration-1 underline-offset-4"
                      : "text-black hover:text-[#088cbc] hover:underline",
                  ]}
                >
                  {link.label}
                </a>
              );
            })
          }
        </div>
      </div>
    </aside>

    <main id="main-content" class="min-h-screen bg-white">
      <EngageContact />
      <SiteHeader backHref={backHref} />
      <div class="bg-white px-8 py-10 lg:px-12 lg:py-12">
        <section class="relative my-6 overflow-hidden py-8 md:my-8 md:py-10 xl:my-0 xl:py-0">
          <Image
            src={logoPng}
            alt={page.h1Title || "ISOv8"}
            class="block w-full"
            decoding="async"
          />

          <div class="absolute inset-0 pl-[48px] pr-8 text-left text-black">
            <div class="absolute left-[48px] top-1/2 max-w-5xl -translate-y-1/2">
              {page.h1Title && (
                <h1 class="max-w-4xl text-[2.625rem] font-[600] leading-[1.08]">
                  {page.h1Title}
                </h1>
              )}

              {page.h2Title && (
                <p class="mt-10 max-w-5xl text-[1.3125rem] font-[400] leading-[1.5] lg:mt-12">
                  {page.h2Title}
                </p>
              )}

              {page.h3Title && (
                <p class="mt-10 max-w-4xl text-[1.3125rem] font-[400] leading-[1.5] lg:mt-12">
                  {page.h3Title}
                </p>
              )}
            </div>
          </div>
        </section>

        {page.body && page.body.length > 0 && (
          <div id="toc-region" class="mt-12 xl:relative xl:grid xl:grid-cols-[minmax(0,1fr)_280px] xl:gap-12">
            <div
              class="pointer-events-none absolute bottom-0 right-[304px] top-0 hidden w-px bg-gray-200 xl:block"
              aria-hidden="true"
            ></div>

            <div>
              <PortableTextRenderer value={page.body} />
            </div>

            {headings.length > 0 && (
              <aside id="toc-rail" class="mt-12 hidden xl:relative xl:mt-0 xl:block xl:self-stretch xl:justify-self-end xl:w-full xl:max-w-[280px] xl:pl-6">
                <div id="toc-panel" class="p-0">
                  <p class="text-[1.25rem] font-[600] leading-tight text-black">
                    Table of Contents
                  </p>

                  <nav aria-label="Table of contents" class="mt-5">
                    <ul class="space-y-3 text-left">
                      {headings.map((heading) => (
                        <li>
                          <a
                            href={`#${heading.id}`}
                            data-toc-link={heading.id}
                            class="text-[1.0625rem] leading-[1.5] text-[#4b5563] transition-colors hover:text-[#088cbc] hover:underline"
                          >
                            {heading.text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </nav>
                </div>
              </aside>
            )}
          </div>
        )}

        {page._updatedAt && (
          <p class="mt-12 text-[0.9375rem] italic text-[#4b5563]">
            Published: {new Date(page._updatedAt).toLocaleDateString("en-GB", { day: "2-digit", month: "2-digit", year: "numeric" })}, {new Date(page._updatedAt).toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit" })}
          </p>
        )}

        <section class="mt-12 border-t border-gray-200 pt-8 text-[#111111]">
          <div class="space-y-4">
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              If you are considering commissioning a container office, workshop, storage unit or secure anti-vandal unit for site use and want clarity on structural suitability before specification is fixed, speak with ISOv8&reg;. A short early discussion prevents disproportionate reinforcement and reactive redesign.
            </p>
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              ISOv8&reg; by ContainerKing&reg; Limited Scunthorpe, North Lincolnshire<br />Tel: 01724 870000<br />Nationwide delivery across England, Scotland &amp; Wales
            </p>
          </div>
        </section>

        <section id="page-legal" class="mt-8 border-t border-gray-200 pt-8 text-[#111111]">
          <div class="space-y-3">
            <p class="text-[1.125rem] font-[600] leading-tight">Legal Disclaimer</p>
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              The content provided in this document is for general information purposes only and is not intended to constitute legal, planning, building control, health and safety, or professional advice. Regulations and site-specific requirements vary widely across the UK. ISOv8&reg; by ContainerKing&reg; does not accept liability for actions taken, losses incurred, or decisions made based on the information provided. Always consult your local authority, planning department, building inspector, legal adviser, or relevant professional before starting any container project. Use of this document is entirely at your own risk.
            </p>
          </div>

          <div class="mt-8 space-y-3">
            <p class="text-[1.125rem] font-[600] leading-tight">Copyright Notice</p>
            <p class="text-[0.9375rem] leading-[1.8] text-[#4b5563]">
              &copy; 2025 ISOv8&reg; by ContainerKing&reg;. All rights reserved. You are welcome to link to this page or share brief excerpts for commentary, review, or non-commercial purposes, provided proper credit is given to ISOv8&reg; by ContainerKing&reg;. No part of this document may be reproduced, distributed, or transmitted in full in any form or by any means without prior written permission from ISOv8&reg; by ContainerKing&reg;.
            </p>
          </div>
        </section>
      </div>
      <SiteFooter />
    </main>
  </div>
  <script>
    const tocRail = document.getElementById("toc-rail");
    const tocPanel = document.getElementById("toc-panel");
    const tocRegion = document.getElementById("toc-region");
    const desktopMq = window.matchMedia("(min-width: 1280px)");

    const resetTocPanel = () => {
      if (!tocPanel) {
        return;
      }

      tocPanel.style.removeProperty("position");
      tocPanel.style.removeProperty("top");
      tocPanel.style.removeProperty("left");
      tocPanel.style.removeProperty("right");
      tocPanel.style.removeProperty("width");
    };

    const updateTocPanel = () => {
      if (!tocRail || !tocPanel || !tocRegion || !desktopMq.matches) {
        resetTocPanel();
        return;
      }

      // Reset before measuring so we get the natural layout position
      resetTocPanel();

      const railRect = tocRail.getBoundingClientRect();
      const regionRect = tocRegion.getBoundingClientRect();
      const panelRect = tocPanel.getBoundingClientRect();
      const railTop = railRect.top + window.scrollY;
      const regionBottom = regionRect.bottom + window.scrollY;
      const panelNaturalLeft = panelRect.left;
      const panelNaturalWidth = panelRect.width;
      const panelOffsetWithinRail = panelNaturalLeft - railRect.left;
      const currentScroll = window.scrollY;
      const fixedTop = 24;
      const startPoint = railTop - fixedTop;
      const stopPoint = regionBottom - tocPanel.offsetHeight - fixedTop;

      if (currentScroll <= startPoint) {
        resetTocPanel();
        return;
      }

      if (currentScroll >= stopPoint) {
        tocPanel.style.position = "absolute";
        tocPanel.style.top = `${Math.max(regionBottom - railTop - tocPanel.offsetHeight, 0)}px`;
        tocPanel.style.left = `${panelOffsetWithinRail}px`;
        tocPanel.style.right = "auto";
        tocPanel.style.width = `${panelNaturalWidth}px`;
        return;
      }

      tocPanel.style.position = "fixed";
      tocPanel.style.top = `${fixedTop}px`;
      tocPanel.style.left = `${panelNaturalLeft}px`;
      tocPanel.style.right = "auto";
      tocPanel.style.width = `${panelNaturalWidth}px`;
    };

    updateTocPanel();
    window.addEventListener("scroll", updateTocPanel, { passive: true });
    window.addEventListener("resize", updateTocPanel);
    desktopMq.addEventListener("change", updateTocPanel);

    // Active heading highlight
    const tocLinks = document.querySelectorAll("[data-toc-link]");
    if (tocLinks.length > 0) {
      const headingIds = Array.from(tocLinks).map(
        (link) => link.getAttribute("data-toc-link")
      );
      const headingEls = headingIds
        .map((id) => document.getElementById(id))
        .filter(Boolean);

      const setActive = (id) => {
        tocLinks.forEach((link) => {
          if (link.getAttribute("data-toc-link") === id) {
            link.classList.remove("text-[#4b5563]");
            link.classList.add("text-[#088cbc]", "underline");
          } else {
            link.classList.add("text-[#4b5563]");
            link.classList.remove("text-[#088cbc]", "underline");
          }
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
            }
          });
        },
        { rootMargin: "0px 0px -70% 0px", threshold: 0 }
      );

      headingEls.forEach((el) => observer.observe(el));
    }
  </script>
</BaseLayout>
