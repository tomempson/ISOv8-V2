---
import { Image } from "astro:assets";
import ContentPageLayout from "../layouts/ContentPageLayout.astro";
import PortableTextRenderer from "../components/portable-text/PortableTextRenderer.astro";
import { getAllPages, getSidebarLinksGroupedByPhaseSection } from "../utils/sanity";
import { extractH2s } from "../utils/portable-text";
import {
  phaseSanityToSidebar,
  sectionSanityToSidebar,
  phaseSanityToLabel,
  sectionSanityToLabel,
} from "../data/taxonomy";
import { SITE_ORIGIN, articleJsonLd } from "../utils/site-meta";
import phase1Img from "../assets/images/phase-1.jpg";

export async function getStaticPaths() {
  const pages = await getAllPages();

  return pages.map((page: any) => {
    const fullSlug = page.phase && page.section
      ? `${page.phase}/${page.section}/${page.slug}`
      : page.slug;

    return {
      params: { slug: fullSlug },
      props: { page, fullSlug },
    };
  });
}

const { page, fullSlug } = Astro.props as { page: any; fullSlug: string };

const currentPath = `/${fullSlug}`;
const headings = extractH2s(page.body);

const breadcrumbItems: { name: string; item?: string }[] = [
  { name: "Home", item: `${SITE_ORIGIN}/` },
];
if (page.phase && phaseSanityToLabel[page.phase]) {
  breadcrumbItems.push({
    name: phaseSanityToLabel[page.phase],
    item: `${SITE_ORIGIN}/?phase=${phaseSanityToSidebar[page.phase]}`,
  });
}
if (page.section && sectionSanityToLabel[page.section]) {
  breadcrumbItems.push({
    name: sectionSanityToLabel[page.section],
    item: `${SITE_ORIGIN}/?phase=${phaseSanityToSidebar[page.phase]}&section=${sectionSanityToSidebar[page.section]}`,
  });
}
breadcrumbItems.push({
  name: page.metaTitle || page.h1Title || "Page",
});

const articleSchema = articleJsonLd({
  headline: page.h1Title || page.metaTitle,
  description: page.metaDescription,
  url: `${SITE_ORIGIN}/${fullSlug}`,
  dateModified: page._updatedAt,
});

const backPhase = page.phase ? phaseSanityToSidebar[page.phase] : null;
const backSection = page.section ? sectionSanityToSidebar[page.section] : null;
const backParams = new URLSearchParams();
if (backPhase) backParams.set("phase", backPhase);
if (backSection) backParams.set("section", backSection);
const backHref = backParams.toString() ? `/?${backParams.toString()}` : "/";

const groupedLinks = await getSidebarLinksGroupedByPhaseSection();
const sidebarLinks =
  page.phase && page.section
    ? groupedLinks[page.phase]?.[page.section] || []
    : [];
const sidebarHeading =
  page.section && sectionSanityToLabel[page.section]
    ? sectionSanityToLabel[page.section]
    : "";

const tocItems = headings.map((h) => ({ id: h.id, label: h.text }));

const publishedDate = page._updatedAt
  ? new Date(page._updatedAt).toLocaleDateString("en-GB", { day: "2-digit", month: "2-digit", year: "numeric" })
  : undefined;
---

<ContentPageLayout
  metaTitle={page.metaTitle ? `ISOv8® | ${page.metaTitle}` : "ISOv8®"}
  description={page.metaDescription}
  keywords={page.metaKeywords}
  ogType="article"
  breadcrumbItems={breadcrumbItems}
  jsonLdExtra={[articleSchema]}
  h1={page.h1Title}
  h2={page.h2Title}
  h3={page.h3Title}
  publishedDate={publishedDate}
  tocItems={tocItems}
  backHref={backHref}
>
  <Image
    slot="sidebar"
    src={phase1Img}
    alt=""
    aria-hidden="true"
    class="block w-full"
    width={350}
    height={250}
    decoding="async"
  />

  <div slot="sidebar" class="flex items-center gap-4 px-[30px] py-8 lg:mt-[18px] lg:px-[45px]">
    <a
      href={backHref}
      aria-label="Back to home"
      class="flex h-5 w-5 shrink-0 items-center justify-center text-black transition-colors hover:text-brand"
    >
      <svg
        class="h-5 w-5"
        viewBox="0 0 20 20"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M13 4L7 10L13 16"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>

    <p class="text-[1.25rem] font-[500] leading-tight text-black">
      {sidebarHeading}
    </p>
  </div>

  <div slot="sidebar" class="px-[30px] pb-10 lg:px-[45px]">
    <div class="flex flex-col gap-6">
      {
        sidebarLinks.map((link) => {
          const isActive = link.href === currentPath;
          return (
            <a
              href={link.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "inline-block text-left text-[1.125rem] font-[400] leading-tight transition-colors",
                isActive
                  ? "text-brand underline decoration-1 underline-offset-4"
                  : "text-black hover:text-brand hover:underline",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </div>
  </div>

  {page.body && page.body.length > 0 && (
    <PortableTextRenderer value={page.body} />
  )}
</ContentPageLayout>
