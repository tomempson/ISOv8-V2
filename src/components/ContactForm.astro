---
import ckLogoMark from "../assets/images/container-king-logo-mark-colour.svg";

interface Props {
  variant?: "modal" | "page";
}

const { variant = "modal" } = Astro.props;
const isPage = variant === "page";

const headerJustify = isPage
  ? "justify-center min-[640px]:justify-between"
  : "justify-between";
const phoneVisibility = isPage
  ? "hidden min-[640px]:block"
  : "block";
---

<div class={`mb-7 flex items-center gap-6 ${headerJustify}`}>
  <div class="flex items-center gap-3">
    <h3 class="text-[2.5rem] font-[600] leading-none text-black">Just As</h3>
    <img
      src={ckLogoMark.src}
      alt="Container King"
      class="-ml-1 h-9 w-auto"
    />
  </div>

  <a
    href="tel:01724870000"
    class={`text-[1.75rem] font-[600] leading-none text-brand transition-opacity hover:opacity-80 ${phoneVisibility}`}
  >
    01724 870000
  </a>
</div>

<form
  id="contact-form"
  name="engage-contact"
  novalidate
>
  <input type="hidden" name="form-name" value="engage-contact" />
  <input type="hidden" name="form-loaded-at" value="" data-form-timing />
  <p class="hidden" aria-hidden="true">
    <label>
      Don&apos;t fill this out if you&apos;re human:
      <input type="text" name="bot-field" tabindex="-1" autocomplete="off" />
    </label>
  </p>

  <div class="grid gap-0 md:grid-cols-2 lg:gap-1">
    <div class="flex flex-col gap-1">
      <label for="contact-name" class="sr-only">Name</label>
      <input
        id="contact-name"
        type="text"
        name="name"
        placeholder="Name"
        autocomplete="name"
        required
        maxlength="80"
        data-contact-input
        class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[1rem] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus-visible:border-brand focus-visible:ring-2 focus-visible:ring-brand/30"
      />
      <p
        id="contact-name-error"
        data-error-for="name"
        aria-live="polite"
        aria-atomic="true"
        class="min-h-[4px] text-[0.75rem] leading-tight text-[#c53d32]"
      ></p>
    </div>

    <div class="flex flex-col gap-1">
      <label for="contact-telephone" class="sr-only">Telephone Number</label>
      <input
        id="contact-telephone"
        type="text"
        name="telephone"
        placeholder="Telephone Number"
        autocomplete="tel"
        inputmode="numeric"
        required
        pattern="^[0-9]{7,15}$"
        data-contact-input
        class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[1rem] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus-visible:border-brand focus-visible:ring-2 focus-visible:ring-brand/30"
      />
      <p
        id="contact-telephone-error"
        data-error-for="telephone"
        aria-live="polite"
        aria-atomic="true"
        class="min-h-[4px] text-[0.75rem] leading-tight text-[#c53d32]"
      ></p>
    </div>

    <div class="flex flex-col gap-1 md:col-span-2">
      <label for="contact-business" class="sr-only">Business Name</label>
      <input
        id="contact-business"
        type="text"
        name="business-name"
        placeholder="Business Name"
        autocomplete="organization"
        required
        maxlength="100"
        data-contact-input
        class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[1rem] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus-visible:border-brand focus-visible:ring-2 focus-visible:ring-brand/30"
      />
      <p
        id="contact-business-error"
        data-error-for="business-name"
        aria-live="polite"
        aria-atomic="true"
        class="min-h-[4px] text-[0.75rem] leading-tight text-[#c53d32]"
      ></p>
    </div>

    <div class="flex flex-col gap-1 md:col-span-2">
      <label for="contact-enquiry" class="sr-only">Enquiry Details</label>
      <textarea
        id="contact-enquiry"
        name="enquiry-details"
        rows="5"
        placeholder="Enquiry Details"
        required
        maxlength="1000"
        autocomplete="off"
        data-contact-input
        class="w-full resize-none rounded-[6px] border border-gray-300 bg-white px-4 py-3 text-[1rem] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus-visible:border-brand focus-visible:ring-2 focus-visible:ring-brand/30"
      ></textarea>
      <p
        id="contact-enquiry-error"
        data-error-for="enquiry-details"
        aria-live="polite"
        aria-atomic="true"
        class="min-h-[4px] text-[0.75rem] leading-tight text-[#c53d32]"
      ></p>
    </div>
  </div>

  <p
    id="contact-form-error"
    role="alert"
    class="mt-2 hidden text-[0.875rem] leading-tight text-[#c53d32]"
  ></p>

  {isPage ? (
    <div class="mt-3 grid grid-cols-2 gap-3">
      <button
        id="contact-submit"
        type="submit"
        class="w-full cursor-pointer rounded-md py-5 text-[1.25rem] font-[500] uppercase tracking-[0.05em] leading-none text-white transition-opacity duration-300 hover:opacity-85 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand disabled:cursor-not-allowed disabled:opacity-60"
        style="background: var(--color-brand);"
      >
        Submit
      </button>
      <a
        href="/"
        class="flex w-full items-center justify-center rounded-md border border-gray-300 py-5 text-[1.25rem] font-[500] uppercase tracking-[0.05em] leading-none text-[#1f1f1f] transition-opacity duration-300 hover:opacity-70 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
      >
        Return Home
      </a>
    </div>
  ) : (
    <button
      id="contact-submit"
      type="submit"
      class="mt-3 w-full cursor-pointer rounded-md py-5 text-[1.25rem] font-[500] uppercase tracking-[0.05em] leading-none text-white transition-opacity duration-300 hover:opacity-85 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand disabled:cursor-not-allowed disabled:opacity-60"
      style="background: var(--color-brand);"
    >
      Submit
    </button>
  )}

  <p class="mt-3 text-center text-[0.875rem] leading-snug text-[#6f6f6f]">
    By submitting this form, you agree to our <a href="/privacy-policy" class="text-brand underline transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand">privacy policy</a>. We will only use your details to respond to your enquiry.
  </p>
</form>

<form name="engage-contact" data-netlify="true" netlify-honeypot="bot-field" hidden>
  <input type="hidden" name="form-name" value="engage-contact" />
  <input name="name" />
  <input name="telephone" />
  <input name="business-name" />
  <textarea name="enquiry-details"></textarea>
</form>

<script>
  (() => {
    const contactForm = document.getElementById("contact-form") as HTMLFormElement | null;
    if (!contactForm) return;

    type FormInput = HTMLInputElement | HTMLTextAreaElement;

    const formLoadedAt = Date.now();
    const timingInput = contactForm.querySelector<HTMLInputElement>("[data-form-timing]");
    if (timingInput) timingInput.value = String(formLoadedAt);

    const contactInputs = Array.from(
      contactForm.querySelectorAll<FormInput>("[data-contact-input]")
    );
    const submitButton = document.getElementById("contact-submit") as HTMLButtonElement | null;
    const formError = document.getElementById("contact-form-error");
    let isSubmitting = false;

    const warnBeforeUnload = (event: BeforeUnloadEvent) => {
      event.preventDefault();
    };

    let warnArmed = false;
    const armBeforeUnload = () => {
      if (warnArmed) return;
      window.addEventListener("beforeunload", warnBeforeUnload);
      warnArmed = true;
    };
    const disarmBeforeUnload = () => {
      if (!warnArmed) return;
      window.removeEventListener("beforeunload", warnBeforeUnload);
      warnArmed = false;
    };

    const validationMessages: Record<string, Record<string, string>> = {
      name: {
        valueMissing: "Please enter your name."
      },
      telephone: {
        valueMissing: "Please enter your telephone number.",
        patternMismatch: "Telephone number must contain 7 to 15 digits only."
      },
      "business-name": {
        valueMissing: "Please enter your business name."
      },
      "enquiry-details": {
        valueMissing: "Please enter your enquiry details."
      }
    };

    const getErrorMessage = (input: FormInput) => {
      const fieldMessages = validationMessages[input.name] ?? {};
      if (input.validity.valueMissing) return fieldMessages.valueMissing ?? "This field is required.";
      if (input.validity.tooShort) return fieldMessages.tooShort ?? "Please enter a little more information.";
      if (input.validity.patternMismatch) return fieldMessages.patternMismatch ?? "Please enter a valid value.";
      return "";
    };

    const setFieldErrorState = (input: FormInput) => {
      const errorElement = contactForm.querySelector<HTMLElement>(`[data-error-for="${input.name}"]`);
      const errorMessage = getErrorMessage(input);
      const hasError = errorMessage.length > 0;
      input.setAttribute("aria-invalid", String(hasError));
      input.classList.toggle("border-[#c53d32]", hasError);
      input.classList.toggle("focus-visible:border-[#c53d32]", hasError);
      input.classList.toggle("border-gray-300", !hasError);
      input.classList.toggle("focus-visible:border-brand", !hasError);
      if (errorElement) {
        errorElement.textContent = errorMessage;
        if (hasError && errorElement.id) {
          input.setAttribute("aria-describedby", errorElement.id);
        } else {
          input.removeAttribute("aria-describedby");
        }
      }
      return !hasError;
    };

    const showFormError = (message: string) => {
      if (!formError) return;
      formError.textContent = message;
      formError.classList.remove("hidden");
    };

    const hideFormError = () => {
      if (!formError) return;
      formError.textContent = "";
      formError.classList.add("hidden");
    };

    const setSubmitting = (submitting: boolean) => {
      isSubmitting = submitting;
      if (submitButton) {
        submitButton.disabled = submitting;
        submitButton.textContent = submitting ? "Submitting…" : "Submit";
      }
    };

    contactInputs.forEach((input) => {
      input.addEventListener("blur", () => setFieldErrorState(input));
      input.addEventListener("input", () => {
        if (input.name === "telephone") input.value = input.value.replace(/\D+/g, "");
        if (input.getAttribute("aria-invalid") === "true") setFieldErrorState(input);
        if (input.value.trim().length > 0) armBeforeUnload();
      });
    });

    contactForm.addEventListener("submit", (event) => {
      event.preventDefault();
      hideFormError();

      if (isSubmitting) return;

      if (Date.now() - formLoadedAt < 3000) {
        showFormError("Please wait a moment before submitting.");
        return;
      }

      const firstInvalidInput = contactInputs.find((input) => !setFieldErrorState(input));
      if (firstInvalidInput) { firstInvalidInput.focus(); return; }

      setSubmitting(true);

      const formData = new FormData(contactForm);
      const params = new URLSearchParams();
      formData.forEach((value, key) => {
        params.append(key, typeof value === "string" ? value : "");
      });
      disarmBeforeUnload();

      fetch("/.netlify/functions/submit-contact", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: params.toString()
      })
        .then(async (response) => {
          const data = await response.json().catch(() => null);
          if (!response.ok) throw new Error(data?.error || "[E-502] The server returned an unexpected response. Please try again.");
          try { sessionStorage.setItem("submission-success", "1"); } catch (_) {}
          window.location.href = "/thank-you/";
        })
        .catch((err: Error) => {
          try {
            const message = err.message && err.message.startsWith("[E-")
              ? err.message
              : "[E-600] Unable to reach our servers. Please check your internet connection and try again.";
            sessionStorage.setItem("submission-error", message);
          } catch (_) {}
          window.location.href = "/error/";
        });
    });
  })();
</script>
