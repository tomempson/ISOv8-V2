---
interface Props {
  class?: string;
  backHref?: string;
}

const {
  class: className = "",
  backHref = "/"
} = Astro.props;
---

<header
  class={`relative h-[110px] overflow-hidden bg-gradient-to-b from-black/65 via-black/20 to-transparent text-white ${className}`}
>
  <div class="absolute inset-0 bg-gradient-to-b from-black/30 to-transparent"></div>

  <a
    href="/"
    aria-label="ISO V8 home"
    class="absolute left-1/2 top-1/2 z-10 hidden -translate-x-1/2 -translate-y-1/2 min-[679px]:block lg:left-12 lg:translate-x-0"
  >
    <img
      src="/assets/images/isov8-logo.svg"
      alt="ISO V8"
      class="w-[300px] max-w-[calc(100vw-120px)]"
      width="300"
      height="40"
      decoding="async"
    />
  </a>

  <a
    href="/"
    aria-label="ISO V8 home"
    class="absolute right-8 top-1/2 z-10 block -translate-y-1/2 min-[679px]:hidden"
  >
    <img
      src="/assets/images/isov8-logo-mark.svg"
      alt="ISO V8"
      class="w-16"
      width="64"
      height="64"
      decoding="async"
    />
  </a>

  <a
    href={backHref}
    aria-label="Back to home"
    class="absolute left-8 top-1/2 z-20 flex h-10 w-10 -translate-y-1/2 items-center justify-center lg:hidden"
  >
    <svg
      class="h-10 w-10"
      viewBox="0 0 40 40"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M25 10L15 20L25 30"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </a>

  <div class="pointer-events-none relative z-10 flex h-full items-center justify-end gap-6 px-8 text-white lg:px-12">
    <nav aria-label="Primary" class="pointer-events-auto hidden items-center gap-10 text-[20px] font-medium lg:flex">
      <a href="/about-us">ABOUT US</a>
      <a href="/inside-v8">INSIDE V8</a>
    </nav>
  </div>
</header>
