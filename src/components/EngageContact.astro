---
import contactBg from "../assets/images/contact-background.svg";
import ckLogoMark from "../assets/images/container-king-logo-mark-colour.svg";
---

<button
  id="engage-button"
  type="button"
  class="engage-button fixed bottom-6 right-6 z-30 flex h-[125px] w-[125px] cursor-pointer items-center justify-center rounded-full bg-transparent p-0 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#088cbc]"
  aria-controls="contact-modal"
  aria-expanded="false"
>
  <svg
    class="engage-button__ring absolute inset-0 h-full w-full -rotate-90"
    viewBox="0 0 125 125"
    aria-hidden="true"
  >
    <circle
      class="engage-button__ring-base"
      cx="62.5"
      cy="62.5"
      r="60"
      pathLength="100"
    />
    <circle
      class="engage-button__ring-progress"
      cx="62.5"
      cy="62.5"
      r="60"
      pathLength="100"
    />
  </svg>
  <div class="engage-button__core relative z-10 flex h-[105px] w-[105px] flex-col items-center justify-center rounded-full bg-white">
    <span class="h-[3px] w-[82px] bg-[#088cbc]"></span>
    <span class="my-2 text-[1.25rem] font-[600] leading-none text-black">ENGAGE</span>
    <span class="h-[3px] w-[82px] bg-[#088cbc]"></span>
  </div>
</button>

<div
  id="contact-overlay"
  class="pointer-events-none fixed inset-0 z-[45] bg-black/70 opacity-0 transition-opacity ease-out"
  aria-hidden="true"
  style="transition-duration: 1000ms;"
></div>

<div
  id="contact-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Contact form"
  inert
  class="pointer-events-none fixed inset-0 z-50 flex items-center justify-center px-6 opacity-0 transition-opacity ease-out"
  aria-hidden="true"
  style="transition-duration: 1000ms;"
>
  <button
    id="contact-close"
    type="button"
    aria-controls="contact-modal"
    aria-expanded="false"
    class="absolute left-16 top-16 z-10 flex cursor-pointer items-center text-white lg:left-20 lg:top-20 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
  >
    <span class="relative flex h-10 w-10 items-center justify-center" aria-hidden="true">
      <span class="absolute h-0.5 w-full rotate-45 bg-current"></span>
      <span class="absolute h-0.5 w-full -rotate-45 bg-current"></span>
    </span>
  </button>

  <div class="relative w-full max-w-[min(94vw,1100px)]">
    <img
      src={contactBg.src}
      alt=""
      aria-hidden="true"
      class="h-auto max-h-[calc(100dvh-72px)] w-full"
      decoding="async"
    />

    <form
      id="contact-form"
      name="engage-contact"
      novalidate
      class="absolute inset-0 flex items-center justify-center px-8 py-8 text-black lg:px-20 lg:py-10"
    >
      <input type="hidden" name="form-name" value="engage-contact" />
      <input type="hidden" name="form-loaded-at" value="" data-form-timing />
      <p class="hidden" aria-hidden="true">
        <label>
          Don&apos;t fill this out if you&apos;re human:
          <input type="text" name="bot-field" tabindex="-1" autocomplete="off" />
        </label>
      </p>

      <div class="w-full max-w-[760px]">
        <div class="mb-7 flex items-center justify-between gap-6">
          <div class="flex items-center gap-3">
            <h3 class="text-[2.5rem] font-[600] leading-none text-black">Just As</h3>
            <img
              src={ckLogoMark.src}
              alt="Container King"
              class="-ml-1 h-9 w-auto"
            />
          </div>

          <a
            href="tel:01724870000"
            class="text-[1.75rem] font-[600] leading-none text-[#088cbc] transition-opacity hover:opacity-80"
          >
            01724 870000
          </a>
        </div>

        <div class="grid gap-0 md:grid-cols-2 lg:gap-1">
          <div class="flex flex-col gap-1">
            <label for="engage-name" class="sr-only">Name</label>
            <input
              id="engage-name"
              type="text"
              name="name"
              placeholder="Name"
              autocomplete="name"
              required
              maxlength="80"
              data-contact-input
              class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[1rem] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus-visible:border-[#088cbc] focus-visible:ring-2 focus-visible:ring-[#088cbc]/30"
            />
            <p
              id="engage-name-error"
              data-error-for="name"
              class="min-h-[4px] text-[0.75rem] leading-tight text-[#c53d32]"
            ></p>
          </div>

          <div class="flex flex-col gap-1">
            <label for="engage-telephone" class="sr-only">Telephone Number</label>
            <input
              id="engage-telephone"
              type="text"
              name="telephone"
              placeholder="Telephone Number"
              autocomplete="tel"
              inputmode="numeric"
              required
              pattern="^[0-9]{7,15}$"
              data-contact-input
              class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[1rem] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus-visible:border-[#088cbc] focus-visible:ring-2 focus-visible:ring-[#088cbc]/30"
            />
            <p
              id="engage-telephone-error"
              data-error-for="telephone"
              class="min-h-[4px] text-[0.75rem] leading-tight text-[#c53d32]"
            ></p>
          </div>

          <div class="flex flex-col gap-1 md:col-span-2">
            <label for="engage-business" class="sr-only">Business Name</label>
            <input
              id="engage-business"
              type="text"
              name="business-name"
              placeholder="Business Name"
              autocomplete="organization"
              required
              maxlength="100"
              data-contact-input
              class="h-12 w-full rounded-[6px] border border-gray-300 bg-white px-4 text-[1rem] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus-visible:border-[#088cbc] focus-visible:ring-2 focus-visible:ring-[#088cbc]/30"
            />
            <p
              id="engage-business-error"
              data-error-for="business-name"
              class="min-h-[4px] text-[0.75rem] leading-tight text-[#c53d32]"
            ></p>
          </div>

          <div class="flex flex-col gap-1 md:col-span-2">
            <label for="engage-enquiry" class="sr-only">Enquiry Details</label>
            <textarea
              id="engage-enquiry"
              name="enquiry-details"
              rows="5"
              placeholder="Enquiry Details"
              required
              maxlength="1000"
              data-contact-input
              class="w-full resize-none rounded-[6px] border border-gray-300 bg-white px-4 py-3 text-[1rem] text-black outline-none transition-colors placeholder:text-[#6f6f6f] focus-visible:border-[#088cbc] focus-visible:ring-2 focus-visible:ring-[#088cbc]/30"
            ></textarea>
            <p
              id="engage-enquiry-error"
              data-error-for="enquiry-details"
              class="min-h-[4px] text-[0.75rem] leading-tight text-[#c53d32]"
            ></p>
          </div>
        </div>

        <p
          id="engage-form-error"
          role="alert"
          class="mt-2 hidden text-[0.875rem] leading-tight text-[#c53d32]"
        ></p>

        <button
          id="engage-submit"
          type="submit"
          class="mt-3 w-full cursor-pointer rounded-md py-5 text-[1.25rem] font-[500] uppercase tracking-[0.05em] leading-none text-white transition-opacity duration-300 hover:opacity-85 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#088cbc] disabled:cursor-not-allowed disabled:opacity-60"
          style="background: linear-gradient(to right, #008eba, #00a9d3);"
        >
          Submit
        </button>

        <p class="mt-3 text-center text-[0.875rem] leading-snug text-[#6f6f6f]">
          By submitting this form, you agree to our <a href="/privacy-policy" class="text-[#088cbc] underline transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#088cbc]">privacy policy</a>. We will only use your details to respond to your enquiry.
        </p>
      </div>
    </form>
  </div>
</div>

<form name="engage-contact" data-netlify="true" netlify-honeypot="bot-field" hidden>
  <input type="hidden" name="form-name" value="engage-contact" />
  <input name="name" />
  <input name="telephone" />
  <input name="business-name" />
  <textarea name="enquiry-details"></textarea>
</form>

<style is:global>
  .engage-button {
    position: fixed;
    isolation: isolate;
  }

  .engage-button::before {
    content: "";
    position: absolute;
    inset: 10px;
    border-radius: 9999px;
    box-shadow:
      0 12px 28px rgba(0, 0, 0, 0.22),
      0 4px 10px rgba(0, 0, 0, 0.14);
    z-index: 0;
  }

  .engage-button__ring {
    filter: drop-shadow(0 14px 36px rgba(0, 0, 0, 0.45));
    z-index: 1;
  }

  .engage-button__ring-base,
  .engage-button__ring-progress {
    fill: none;
    stroke-width: 5;
  }

  .engage-button__ring-base {
    stroke: #ffffff;
  }

  .engage-button__ring-progress {
    stroke: #088cbc;
    stroke-dasharray: 100 100;
    stroke-dashoffset: 100.1;
    stroke-linecap: butt;
    opacity: 0;
    transition:
      stroke-dashoffset 900ms ease-in-out,
      opacity 0ms linear 900ms;
  }

  .engage-button:is(:hover, :focus-visible, .is-active) .engage-button__ring-progress,
  .engage-button.is-active .engage-button__ring-progress {
    opacity: 1;
    stroke-dashoffset: 0;
    transition:
      opacity 0ms linear 0ms,
      stroke-dashoffset 900ms ease-in-out;
  }
</style>

<script>
  (() => {
    const engageButton = document.getElementById("engage-button");
    const contactOverlay = document.getElementById("contact-overlay");
    const contactModal = document.getElementById("contact-modal");
    const contactClose = document.getElementById("contact-close");
    const contactForm = document.getElementById("contact-form");

    let lockedScrollY = 0;
    let pageLockCount = 0;

    const warnBeforeUnload = (event) => {
      event.preventDefault();
    };

    const getTransitionDuration = (element) => {
      const durationSeconds = Number.parseFloat(
        window.getComputedStyle(element).transitionDuration
      );

      return Number.isNaN(durationSeconds) ? 0 : durationSeconds * 1000;
    };

    const lockPageScroll = () => {
      if (pageLockCount === 0) {
        lockedScrollY = window.scrollY;
        document.documentElement.style.overflow = "hidden";
        document.body.style.position = "fixed";
        document.body.style.top = `-${lockedScrollY}px`;
        document.body.style.left = "0";
        document.body.style.right = "0";
        document.body.style.width = "100%";
        document.body.style.overflow = "hidden";
      }

      pageLockCount += 1;
    };

    const unlockPageScroll = () => {
      if (pageLockCount === 0) {
        return;
      }

      pageLockCount -= 1;

      if (pageLockCount > 0) {
        return;
      }

      document.documentElement.style.removeProperty("overflow");
      document.body.style.removeProperty("position");
      document.body.style.removeProperty("top");
      document.body.style.removeProperty("left");
      document.body.style.removeProperty("right");
      document.body.style.removeProperty("width");
      document.body.style.removeProperty("overflow");
      window.scrollTo({ top: lockedScrollY, behavior: "instant" });
    };

    if (engageButton && contactOverlay && contactModal && contactClose) {
      let isContactAnimating = false;
      let contactAnimationTimer;

      const setInertOnPageContent = (isOpen) => {
        const parent = contactModal.parentElement;
        if (!parent) return;
        for (const child of parent.children) {
          if (child === contactModal || child === contactOverlay) continue;
          if (isOpen) {
            child.setAttribute("inert", "");
          } else {
            child.removeAttribute("inert");
          }
        }
      };

      const setContactState = (isOpen) => {
        if (isOpen) {
          window.addEventListener("beforeunload", warnBeforeUnload);
        } else {
          window.removeEventListener("beforeunload", warnBeforeUnload);
        }
        engageButton.setAttribute("aria-expanded", String(isOpen));
        contactClose.setAttribute("aria-expanded", String(isOpen));
        engageButton.classList.toggle("is-active", isOpen);
        contactOverlay.setAttribute("aria-hidden", String(!isOpen));
        contactModal.setAttribute("aria-hidden", String(!isOpen));
        contactOverlay.classList.toggle("opacity-0", !isOpen);
        contactOverlay.classList.toggle("opacity-100", isOpen);
        contactModal.classList.toggle("opacity-0", !isOpen);
        contactModal.classList.toggle("opacity-100", isOpen);
        contactOverlay.classList.toggle("pointer-events-none", !isOpen);
        contactOverlay.classList.toggle("pointer-events-auto", isOpen);
        contactModal.classList.toggle("pointer-events-none", !isOpen);
        contactModal.classList.toggle("pointer-events-auto", isOpen);
        setInertOnPageContent(isOpen);
        if (isOpen) {
          contactModal.removeAttribute("inert");
          contactClose.focus();
        } else {
          contactModal.setAttribute("inert", "");
        }
      };

      const finishContactTransition = () => {
        isContactAnimating = false;
        engageButton.disabled = false;
        contactClose.disabled = false;
        const isOpen = engageButton.getAttribute("aria-expanded") === "true";
        if (!isOpen) {
          unlockPageScroll();
          engageButton.focus();
        }
        window.clearTimeout(contactAnimationTimer);
      };

      const requestContactState = (nextIsOpen) => {
        const currentIsOpen = engageButton.getAttribute("aria-expanded") === "true";
        if (isContactAnimating || currentIsOpen === nextIsOpen) {
          return;
        }

        isContactAnimating = true;
        engageButton.disabled = true;
        contactClose.disabled = true;
        if (nextIsOpen) {
          lockPageScroll();
        }
        setContactState(nextIsOpen);

        contactAnimationTimer = window.setTimeout(
          finishContactTransition,
          getTransitionDuration(contactModal) + 50
        );
      };

      engageButton.addEventListener("click", () => {
        if (window.innerWidth < 1280) {
          window.location.href = "/contact/";
          return;
        }
        requestContactState(true);
      });

      contactClose.addEventListener("click", () => {
        requestContactState(false);
      });

      contactOverlay.addEventListener("click", () => {
        requestContactState(false);
      });

      contactModal.addEventListener("transitionend", (event) => {
        if (event.target === contactModal && event.propertyName === "opacity") {
          finishContactTransition();
        }
      });

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          requestContactState(false);
        }
      });

      window.addEventListener("resize", () => {
        if (window.innerWidth < 1280) {
          const isOpen = engageButton.getAttribute("aria-expanded") === "true";
          if (isOpen) {
            isContactAnimating = false;
            requestContactState(false);
          }
        }
      });
    }

    if (contactForm) {
      const formLoadedAt = Date.now();
      const timingInput = contactForm.querySelector("[data-form-timing]");
      if (timingInput) timingInput.value = String(formLoadedAt);

      const contactInputs = Array.from(
        contactForm.querySelectorAll("[data-contact-input]")
      );
      const submitButton = document.getElementById("engage-submit");
      const formError = document.getElementById("engage-form-error");
      let isSubmitting = false;

      const validationMessages = {
        name: {
          valueMissing: "Please enter your name."
        },
        telephone: {
          valueMissing: "Please enter your telephone number.",
          patternMismatch: "Telephone number must contain 7 to 15 digits only."
        },
        "business-name": {
          valueMissing: "Please enter your business name."
        },
        "enquiry-details": {
          valueMissing: "Please enter your enquiry details."
        }
      };

      const getErrorMessage = (input) => {
        const fieldMessages = validationMessages[input.name] ?? {};

        if (input.validity.valueMissing) {
          return fieldMessages.valueMissing ?? "This field is required.";
        }

        if (input.validity.tooShort) {
          return fieldMessages.tooShort ?? "Please enter a little more information.";
        }

        if (input.validity.patternMismatch) {
          return fieldMessages.patternMismatch ?? "Please enter a valid value.";
        }

        return "";
      };

      const setFieldErrorState = (input) => {
        const errorElement = contactForm.querySelector(
          `[data-error-for="${input.name}"]`
        );
        const errorMessage = getErrorMessage(input);
        const hasError = errorMessage.length > 0;

        input.setAttribute("aria-invalid", String(hasError));
        input.classList.toggle("border-[#c53d32]", hasError);
        input.classList.toggle("focus-visible:border-[#c53d32]", hasError);
        input.classList.toggle("border-gray-300", !hasError);
        input.classList.toggle("focus-visible:border-[#088cbc]", !hasError);

        if (errorElement) {
          errorElement.textContent = errorMessage;
          if (hasError && errorElement.id) {
            input.setAttribute("aria-describedby", errorElement.id);
          } else {
            input.removeAttribute("aria-describedby");
          }
        }

        return !hasError;
      };

      const showFormError = (message) => {
        if (!formError) return;
        formError.textContent = message;
        formError.classList.remove("hidden");
      };

      const hideFormError = () => {
        if (!formError) return;
        formError.textContent = "";
        formError.classList.add("hidden");
      };

      const setSubmitting = (submitting) => {
        isSubmitting = submitting;
        if (submitButton) {
          submitButton.disabled = submitting;
          submitButton.textContent = submitting ? "Submitting\u2026" : "Submit";
        }
      };

      contactInputs.forEach((input) => {
        input.addEventListener("blur", () => {
          setFieldErrorState(input);
        });

        input.addEventListener("input", () => {
          if (input.name === "telephone") {
            input.value = input.value.replace(/\D+/g, "");
          }

          if (input.getAttribute("aria-invalid") === "true") {
            setFieldErrorState(input);
          }
        });
      });

      contactForm.addEventListener("submit", (event) => {
        event.preventDefault();
        hideFormError();

        if (isSubmitting) return;

        if (Date.now() - formLoadedAt < 3000) {
          showFormError("Please wait a moment before submitting.");
          return;
        }

        const firstInvalidInput = contactInputs.find((input) => !setFieldErrorState(input));

        if (firstInvalidInput) {
          firstInvalidInput.focus();
          return;
        }

        setSubmitting(true);

        const formData = new FormData(contactForm);
        window.removeEventListener("beforeunload", warnBeforeUnload);

        fetch("/.netlify/functions/submit-contact", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams(formData).toString()
        })
          .then(async (response) => {
            const data = await response.json().catch(() => null);
            if (!response.ok) throw new Error(data?.error || "[E-502] The server returned an unexpected response. Please try again.");
            window.location.href = "/thank-you/";
          })
          .catch((err) => {
            try {
              const message = err.message && err.message.startsWith("[E-")
                ? err.message
                : "[E-600] Unable to reach our servers. Please check your internet connection and try again.";
              sessionStorage.setItem("submission-error", message);
            } catch (_) {}
            window.location.href = "/error/";
          });
      });
    }
  })();
</script>
