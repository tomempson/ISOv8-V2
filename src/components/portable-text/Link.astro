---
import type { Props as MarkProps } from "astro-portabletext/types";

type Props = MarkProps;

const { node } = Astro.props;
const { href, openInNewTab } = node;
const isExternal = href && !href.startsWith("/") && !href.startsWith("#");
---

<a
  href={href}
  target={openInNewTab ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
  class="text-brand underline decoration-1 underline-offset-4 transition-colors hover:text-[#055472]"
>
  <slot />{openInNewTab && <span class="sr-only"> (opens in a new tab)</span>}
</a>
